        "faq_4RH48d": {
          "type": "faq",
          "settings": {
            "question": "Is VIBBO ethically sourced?",
            "answer": "VIBBO is ethically sourced: we're actively working toward B Corp certification in the coming quarters, with all ingredients sustainably produced, fully traceable from the dirt to the cup— no B.S."
