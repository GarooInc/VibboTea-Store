        "faq_xUfMyA": {
          "type": "faq",
          "settings": {
            "question": "Where do we sort our ingredients from?",
            "answer": "VIBBO sources all ingredients 100% from Guatemala across various regions, directly from local farmers and supporting surrounding communities—embracing our roots from soil to steep. No jokes, come and find out, we dare you ;)."
          }
        },
        "faq_YVfbax": {
          "type": "faq",
          "settings": {
            "question": "How should I drink it?",
            "answer": "Follow the GIF steps above: hot, cold, or as a mocktail. We're not just boring tea, we're an ingredient meant to be had fun with. Or drink it however you want; quite honestly, we don't care."
          }
        },
        "faq_TyxJfY": {
          "type": "faq",
          "settings": {
            "question": "How much, when, and how often should I drink VIBBO?",
            "answer": "Sip your chosen VIBBO blend daily, Hydra Boost mornings or mid-afternoon for smooth energy, Gut Bliss anytime you want a fresh reset ritual, Chill Vibes evenings or slow moments when you want to wind down: steeped hot, iced, or as a mocktail, max 3-4 per day based on your flow, or inner chaos."
          }
        },
        "faq_t9PGRg": {
          "type": "faq",
          "settings": {
            "question": "Are there any artificial flavors, sweeteners, or additives in our blends?",
            "answer": "All natural baby."
          }
        },
        "faq_Nbb6HX": {
          "type": "faq",
          "settings": {
            "question": "What’s the shelf life and storage advice for our blends?",
            "answer": "VIBBO goes vibbin' for 24 months post-packaging, stash at room temp in a fresh, dry spot, no humidity please."
          }
        }
