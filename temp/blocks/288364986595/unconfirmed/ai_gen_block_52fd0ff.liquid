{% doc %}
  @prompt
    Add a "Sold Out" badge overlay in the corner of product cards on the collection/shop page for products that have the tag "SOLD OUT". The badge should appear visually on the product image thumbnail without affecting inventory or purchase behavior. Style it to match the store's existing badge design (similar to sale badges). It should only show when the product has the "SOLD OUT" tag.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-sold-out-badge-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-sold-out-badge__product-card-{{ ai_gen_id }} {
    position: relative;
    display: block;
  }

  .ai-sold-out-badge__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .ai-sold-out-badge__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-sold-out-badge__badge-{{ ai_gen_id }} {
    position: absolute;
    {% if block.settings.badge_position == 'top-left' %}
      top: {{ block.settings.badge_offset }}px;
      left: {{ block.settings.badge_offset }}px;
    {% elsif block.settings.badge_position == 'top-right' %}
      top: {{ block.settings.badge_offset }}px;
      right: {{ block.settings.badge_offset }}px;
    {% elsif block.settings.badge_position == 'bottom-left' %}
      bottom: {{ block.settings.badge_offset }}px;
      left: {{ block.settings.badge_offset }}px;
    {% else %}
      bottom: {{ block.settings.badge_offset }}px;
      right: {{ block.settings.badge_offset }}px;
    {% endif %}
    background-color: {{ block.settings.badge_background_color }};
    color: {{ block.settings.badge_text_color }};
    padding: {{ block.settings.badge_padding_vertical }}px {{ block.settings.badge_padding_horizontal }}px;
    border-radius: {{ block.settings.badge_border_radius }}px;
    font-size: {{ block.settings.badge_font_size }}px;
    font-weight: {{ block.settings.badge_font_weight }};
    text-transform: {{ block.settings.badge_text_transform }};
    letter-spacing: {{ block.settings.badge_letter_spacing }}px;
    z-index: 10;
    pointer-events: none;
    {% if block.settings.badge_border_width > 0 %}
      border: {{ block.settings.badge_border_width }}px solid {{ block.settings.badge_border_color }};
    {% endif %}
    {% if block.settings.badge_shadow %}
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
    {% endif %}
  }

  .ai-sold-out-badge__product-info-{{ ai_gen_id }} {
    margin-top: 12px;
  }

  .ai-sold-out-badge__product-title-{{ ai_gen_id }} {
    font-size: 16px;
    margin: 0 0 8px;
    color: #333333;
  }

  .ai-sold-out-badge__product-price-{{ ai_gen_id }} {
    font-size: 14px;
    color: #666666;
  }

  @media screen and (max-width: 749px) {
    .ai-sold-out-badge__badge-{{ ai_gen_id }} {
      font-size: {{ block.settings.badge_font_size | times: 0.85 }}px;
      padding: {{ block.settings.badge_padding_vertical | times: 0.85 }}px {{ block.settings.badge_padding_horizontal | times: 0.85 }}px;
    }
  }
{% endstyle %}

<div class="ai-sold-out-badge-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.product %}
    {% assign product = block.settings.product %}
    {% assign has_sold_out_tag = false %}
    
    {% for tag in product.tags %}
      {% assign tag_upcase = tag | upcase %}
      {% if tag_upcase == 'SOLD OUT' %}
        {% assign has_sold_out_tag = true %}
        {% break %}
      {% endif %}
    {% endfor %}

    <a href="{{ product.url }}" class="ai-sold-out-badge__product-card-{{ ai_gen_id }}">
      <div class="ai-sold-out-badge__image-wrapper-{{ ai_gen_id }}">
        {% if product.featured_image %}
          <img
            src="{{ product.featured_image | image_url: width: 600 }}"
            alt="{{ product.featured_image.alt | escape }}"
            loading="lazy"
            width="{{ product.featured_image.width }}"
            height="{{ product.featured_image.height }}"
            class="ai-sold-out-badge__image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-sold-out-badge__image-placeholder-{{ ai_gen_id }}">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
        {% endif %}

        {% if has_sold_out_tag %}
          <span class="ai-sold-out-badge__badge-{{ ai_gen_id }}">
            {{ block.settings.badge_text }}
          </span>
        {% endif %}
      </div>

      <div class="ai-sold-out-badge__product-info-{{ ai_gen_id }}">
        <h3 class="ai-sold-out-badge__product-title-{{ ai_gen_id }}">{{ product.title }}</h3>
        <div class="ai-sold-out-badge__product-price-{{ ai_gen_id }}">
          {{ product.price | money }}
        </div>
      </div>
    </a>
  {% else %}
    <div class="ai-sold-out-badge__product-card-{{ ai_gen_id }}">
      <div class="ai-sold-out-badge__image-wrapper-{{ ai_gen_id }}">
        <div class="ai-sold-out-badge__image-placeholder-{{ ai_gen_id }}">
          {{ 'product-1' | placeholder_svg_tag }}
        </div>
        <span class="ai-sold-out-badge__badge-{{ ai_gen_id }}">
          {{ block.settings.badge_text }}
        </span>
      </div>
      <div class="ai-sold-out-badge__product-info-{{ ai_gen_id }}">
        <p style="color: #999; font-size: 14px; margin-top: 12px;">Select a product to preview the badge</p>
      </div>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Sold out badge",
  "settings": [
    {
      "type": "header",
      "content": "Product"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "paragraph",
      "content": "This block displays a badge overlay on products with the 'SOLD OUT' tag. Add this to your collection page template to show badges on product cards."
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Badge style"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "SOLD OUT"
    },
    {
      "type": "select",
      "id": "badge_position",
      "label": "Position",
      "options": [
        {
          "value": "top-left",
          "label": "Top left"
        },
        {
          "value": "top-right",
          "label": "Top right"
        },
        {
          "value": "bottom-left",
          "label": "Bottom left"
        },
        {
          "value": "bottom-right",
          "label": "Bottom right"
        }
      ],
      "default": "top-left"
    },
    {
      "type": "range",
      "id": "badge_offset",
      "label": "Offset from edge",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "color",
      "id": "badge_background_color",
      "label": "Background",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Text",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "badge_font_size",
      "label": "Font size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "select",
      "id": "badge_font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "700"
    },
    {
      "type": "select",
      "id": "badge_text_transform",
      "label": "Text transform",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        },
        {
          "value": "lowercase",
          "label": "Lowercase"
        },
        {
          "value": "capitalize",
          "label": "Capitalize"
        }
      ],
      "default": "uppercase"
    },
    {
      "type": "range",
      "id": "badge_letter_spacing",
      "label": "Letter spacing",
      "min": 0,
      "max": 3,
      "step": 0.5,
      "unit": "px",
      "default": 0.5
    },
    {
      "type": "range",
      "id": "badge_padding_vertical",
      "label": "Vertical padding",
      "min": 2,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 6
    },
    {
      "type": "range",
      "id": "badge_padding_horizontal",
      "label": "Horizontal padding",
      "min": 4,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "badge_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "badge_shadow",
      "label": "Show shadow",
      "default": true
    },
    {
      "type": "header",
      "content": "Badge border"
    },
    {
      "type": "range",
      "id": "badge_border_width",
      "label": "Border width",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "color",
      "id": "badge_border_color",
      "label": "Border color",
      "default": "#FFFFFF"
    }
  ],
  "presets": [
    {
      "name": "Sold out badge"
    }
  ]
}
{% endschema %}