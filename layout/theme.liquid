<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    {% # Inlined CSS Variables %}
    {% render 'css-variables' %}

    {% comment %}
      Font preloading:
      1. Preconnect to font CDN for faster connection
      2. Preload only the critical font variant (base weight)
      3. Additional variants load on-demand via @font-face
    {% endcomment %}
    {% unless settings.type_primary_font.system? %}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>

      {% comment %} Preload the base font variant for initial page render {% endcomment %}
      {% comment %} {{ settings.type_primary_font | font_url | preload_tag: as: 'font', crossorigin: 'anonymous' }} {% endcomment %}
    {% endunless %}

    {% # Load and preload the critical CSS %}
    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}
    {{ 'application.css' | asset_url | stylesheet_tag: preload: true }}

    {% comment %} Custom Fonts {% endcomment %}
    {{ 'custom-fonts.css' | asset_url | stylesheet_tag }}


    {% # Social, title, etc. %}
    {% render 'meta-tags' %}

    {{ content_for_header }}
    <script>
      (function() {
        var hardRedirects = {
          '/shop': '/collections/shop'
        };
        var path = window.location.pathname;
        if (hardRedirects[path]) {
          window.location.replace(hardRedirects[path]);
        }
      })();
    </script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script async type="text/javascript" src="https://static.klaviyo.com/onsite/js/klaviyo.js?company_id=Wujgaz"></script>
  </head>

  <body{% if request.path contains '/apps/' %} class="page-app-route"{% endif %}>
    {% sections 'header-group' %}

    {{ content_for_layout }}

    {% sections 'footer-group' %}

    <script>
      (function stackBottomWidgets() {
        function findKlaviyoTeaser() {
          return document.querySelector('[class*="kl-private-reset-css"], [class*="kl-teaser"], [class*="Teaser-pointer"]');
        }
        function findCookieBanner() {
          var selectors = [
            '#pandectes-banner',
            '[id*="pandectes"]',
            '[class*="pandectes"]',
            '.cc-window',
            '[class*="cookie-consent"]',
            '[class*="cookie-banner"]',
            '[aria-label*="cookie" i]',
            '[aria-label*="consent" i]'
          ];
          for (var i = 0; i < selectors.length; i++) {
            var el = document.querySelector(selectors[i]);
            if (el) return el;
          }
          var allFixed = document.querySelectorAll('body > div');
          for (var j = 0; j < allFixed.length; j++) {
            var s = window.getComputedStyle(allFixed[j]);
            if (s.position === 'fixed' && parseInt(s.bottom) <= 20 && parseInt(s.left) <= 20) {
              var isKlaviyo = allFixed[j].querySelector('[class*="kl-private"], [class*="Teaser-pointer"]');
              if (!isKlaviyo && allFixed[j].offsetWidth < 200 && allFixed[j].offsetHeight < 200) {
                return allFixed[j];
              }
            }
          }
          return null;
        }
        function adjust() {
          var klaviyo = findKlaviyoTeaser();
          var cookie = findCookieBanner();
          if (klaviyo && cookie) {
            var kRect = klaviyo.getBoundingClientRect();
            var cRect = cookie.getBoundingClientRect();
            if (Math.abs(kRect.left - cRect.left) < 120 && Math.abs(kRect.bottom - cRect.bottom) < 120) {
              cookie.style.setProperty('bottom', (window.innerHeight - kRect.top + 8) + 'px', 'important');
              cookie.style.setProperty('transition', 'bottom 0.3s ease', 'important');
            }
          }
        }
        var obs = new MutationObserver(function() { setTimeout(adjust, 500); });
        obs.observe(document.body, { childList: true, subtree: true });
        window.addEventListener('load', function() { setTimeout(adjust, 1500); setTimeout(adjust, 3000); });
      })();
    </script>

    <script>
      (function() {
        var rewrites = {
          '/pages/about-us':        '/about-us',
          '/pages/partner-with-us': '/partner-with-us',
          '/pages/contact-us':      '/contact-us',
          '/collections/shop':      '/shop'
        };

        var path = window.location.pathname;

        for (var from in rewrites) {
          if (path.startsWith(from)) {
            var clean = path.replace(from, rewrites[from]);
            history.replaceState(null, '', clean + window.location.search + window.location.hash);
            break;
          }
        }
      })();
    </script>

  </body>
</html>
