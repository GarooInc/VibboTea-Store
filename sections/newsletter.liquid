
<div 
class="w-screen min-h-[50vh] bg-[#EBEBEB]  flex flex-col-reverse md:grid
 md:grid-cols-[3fr_4fr] justify-between"
style="width: 100vw; margin-left: calc(50% - 50vw);"
>

  <div class="w-full flex justify-center items-end pt-10">
    <img 
      src="{{ section.settings.imagen | image_url: width: 600 }}" 
      alt="Imagen"
      class="md:w-[30vw] w-[65vw] max-w-md object-contain"
      width="{{ section.settings.background_image.width }}"
      height="{{ section.settings.background_image.height }}"
    >
  </div>

  <div class="w-full flex items-center-safe justify-center  px-10 pt-8">
    <div class="text-left">
      <div class="text-left md:max-w-180 mx-auto">
        <h2 class="hidden md:block md:text-5xl text-center font-bold font-bricolage mb-4">
          {{ section.settings.title }}</h2>

        <h2 class="md:hidden text-3xl text-center font-bold font-bricolage mb-4 whitespace-nowrap">
          {{ section.settings.title_mobile }}</h2>



      </div>

      <div class="flex justify-center mx-auto w-full">
        <div class="klaviyo-form-UcYx3V"></div>
      </div>

  </div>
</div>


</div>




{% schema %}
{
  "name": "Newsletter",
  "settings": [
    {
      "type": "image_picker",
      "id": "imagen",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Join the tribe"
    },
    {
      "type": "textarea",
      "id": "texto1",
      "label": "Texto 1",
      "default": "Sign Up to our newsletter and be the first to know about our launch and exclusive offers"
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Placeholder",
      "default": "email address"
    },
    {
      "type": "text",
      "id": "title_mobile",
      "label": "Title Mobile",
      "default": "You know you want to"
    }
  ],
  "presets": [
    {
      "name": "Newsletter",
    }
  ]
}
{% endschema %}
