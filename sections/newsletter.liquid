
<style>
  /* Subtítulo Klaviyo más grande */
  .klaviyo-form-UcYx3V p,
  .klaviyo-form-UcYx3V div[data-testid="form-component"] p,
  .klaviyo-form-UcYx3V span,
  .klaviyo-form-UcYx3V div[class*="text"],
  .klaviyo-form-UcYx3V div[class*="paragraph"] {
    font-size: 17px !important;
    font-weight: 500 !important;
    line-height: 1.5 !important;
  }
</style>

<div
  class="newsletter-section w-screen bg-[#EBEBEB] overflow-hidden"
  style="width: 100vw; margin-left: calc(50% - 50vw);"
>
  <!-- Título: ancho completo, centrado -->
  <div class="pt-3 pb-0 px-6">
    <h2 class="hidden md:block text-5xl font-bold font-bricolage text-center leading-tight mb-0">
      {{ section.settings.title }}
    </h2>
    <h2 class="md:hidden text-3xl font-bold font-bricolage text-center leading-tight mb-0">
      {{ section.settings.title_mobile }}
    </h2>
  </div>

  <!-- Grid: latas izquierda (solo desktop) + form derecha -->
  <div class="md:grid md:grid-cols-[3fr_4fr] md:items-end flex flex-col">

    <!-- Imagen: solo desktop, alineada al fondo -->
    <div class="hidden md:flex justify-center items-end">
      <img
        src="{{ section.settings.imagen | image_url: width: 600 }}"
        alt="Imagen"
        class="w-[30vw] max-w-md object-contain block"
        width="{{ section.settings.background_image.width }}"
        height="{{ section.settings.background_image.height }}"
      >
    </div>

    <!-- Klaviyo form -->
    <div class="flex flex-col justify-end px-10 pb-0 pt-1">
      <div class="klaviyo-form-UcYx3V"></div>
    </div>

  </div>
</div>




{% schema %}
{
  "name": "Newsletter",
  "settings": [
    {
      "type": "image_picker",
      "id": "imagen",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Join the tribe"
    },
    {
      "type": "textarea",
      "id": "texto1",
      "label": "Texto 1",
      "default": "Sign Up to our newsletter and be the first to know about our launch and exclusive offers"
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Placeholder",
      "default": "email address"
    },
    {
      "type": "text",
      "id": "title_mobile",
      "label": "Title Mobile",
      "default": "You know you want to"
    }
  ],
  "presets": [
    {
      "name": "Newsletter",
    }
  ]
}
{% endschema %}
