<section class="about-us-pledge-section full-width flex flex-col font-bricolage relative range-height-section">
  <div
    class="pledge-stage relative w-full px-6 lg:px-28 md:py-20 py-10 pb-12 md:pb-20
           bg-[#FFF4DA] bg-cover bg-center bg-no-repeat"
    style="
      {% if section.settings.bg_image %}
        background-image: url('{{ section.settings.bg_image | image_url: width: 2000 }}');
      {% endif %}">
    <div class="absolute inset-0 bg-black opacity-30"></div>

    <div class="pledge-hero-copy relative z-10 pb-10 md:pb-14">
      {% if section.settings.eyebrow != blank %}
        <p class="text-5xl md:text-7xl sm:text-5xl mx-auto font-bold text-white">
          {{ section.settings.eyebrow }}
        </p>
      {% endif %}

      <div class="w-full flex justify-end">
        {% if section.settings.title != blank %}
          <h2 class="text-2xl md:text-3xl sm:text-3xl font-bold w-full
            text-right tracking-tight text-white max-w-2xl sm:max-w-md md:max-w-2xl pt-10">
            {{ section.settings.title }}
          </h2>
        {% endif %}
      </div>
    </div>

    <div class="pledge-cards relative z-10">
      <div class="pledge-card flex items-center justify-center rounded-xl bg-white p-5 md:p-6 h-[320px] md:h-[400px]">
        <img
          src="{{ section.settings.image | image_url: width: 1200 }}"
          alt="Imagen 1"
          class="w-full h-auto max-h-[280px] md:max-h-[360px] object-contain object-center"
          width="{{ section.settings.image.width }}"
          height="{{ section.settings.image.height }}"
          loading="lazy"
        >
      </div>

      <div class="pledge-card flex items-center justify-center rounded-xl bg-white p-5 md:p-6 h-[320px] md:h-[400px]">
        <img
          src="{{ section.settings.image2 | image_url: width: 1200 }}"
          alt="Imagen 2"
          class="w-full h-auto max-h-[280px] md:max-h-[360px] object-contain object-center"
          width="{{ section.settings.image2.width }}"
          height="{{ section.settings.image2.height }}"
          loading="lazy"
        >
      </div>

      <div class="pledge-card flex items-center justify-center rounded-xl bg-white p-5 md:p-6 h-[320px] md:h-[400px]">
        <img
          src="{{ section.settings.image3 | image_url: width: 1200 }}"
          alt="Imagen 3"
          class="w-full h-auto max-h-[280px] md:max-h-[360px] object-contain object-center"
          width="{{ section.settings.image3.width }}"
          height="{{ section.settings.image3.height }}"
          loading="lazy"
        >
      </div>
    </div>

    <div class="pledge-carousel relative z-10 w-full pt-8 pb-4 overflow-visible">
      <div class="relative w-full overflow-visible flex items-center">
        <div id="pledgeTrack-{{ section.id }}" class="pledge-scroll-track flex gap-8 items-center">
          {% for i in (1..4) %}
            {% if section.settings.image %}
              <div class="pledge-scroll-card min-w-[72vw] bg-white/95 rounded-xl flex items-center justify-center p-5 h-[260px] shadow-sm">
                <img
                  src="{{ section.settings.image | image_url: width: 1200 }}"
                  alt="Imagen 1"
                  class="w-full h-auto max-h-[230px] object-contain object-center"
                  width="{{ section.settings.image.width }}"
                  height="{{ section.settings.image.height }}"
                  loading="eager"
                >
              </div>
            {% endif %}

            {% if section.settings.image2 %}
              <div class="pledge-scroll-card min-w-[72vw] bg-white/95 rounded-xl flex items-center justify-center p-5 h-[260px] shadow-sm">
                <img
                  src="{{ section.settings.image2 | image_url: width: 1200 }}"
                  alt="Imagen 2"
                  class="w-full h-auto max-h-[230px] object-contain object-center"
                  width="{{ section.settings.image2.width }}"
                  height="{{ section.settings.image2.height }}"
                  loading="eager"
                >
              </div>
            {% endif %}

            {% if section.settings.image3 %}
              <div class="pledge-scroll-card min-w-[72vw] bg-white/95 rounded-xl flex items-center justify-center p-5 h-[260px] shadow-sm">
                <img
                  src="{{ section.settings.image3 | image_url: width: 1200 }}"
                  alt="Imagen 3"
                  class="w-full h-auto max-h-[230px] object-contain object-center"
                  width="{{ section.settings.image3.width }}"
                  height="{{ section.settings.image3.height }}"
                  loading="eager"
                >
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>

  {% if section.settings.text != blank %}
    <div class="pledge-text bg-white relative w-full flex justify-center py-10 md:py-16 px-4 text-center">
      <div class="max-w-2xl md:max-w-6xl text-xl sm:text-3xl md:text-4xl text-black">
        {{ section.settings.text }}
      </div>
    </div>
  {% endif %}
</section>

<style>
@keyframes pledge-infinite-scroll-{{ section.id }} {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

.about-us-pledge-section .pledge-scroll-track {
  animation: pledge-infinite-scroll-{{ section.id }} var(--scroll-duration, 36s) var(--scroll-delay, 0s) linear infinite;
}

.about-us-pledge-section .pledge-scroll-track:hover {
  animation-play-state: paused;
}

.about-us-pledge-section .pledge-scroll-card {
  transition: transform 0.4s ease, opacity 0.4s ease;
  transform: scale(0.95);
}

.about-us-pledge-section .pledge-scroll-card.is-center {
  transform: scale(1.03);
  z-index: 10;
}

.about-us-pledge-section .pledge-scroll-card img {
  transition: transform 0.4s ease;
}

.about-us-pledge-section .pledge-scroll-card.is-center img {
  transform: scale(1.02);
}

/* pledge-layout-v4: text and cards stacked in flow inside field background */
.about-us-pledge-section .pledge-cards {
  display: none;
  gap: calc(var(--spacing) * 5);
}

.about-us-pledge-section .pledge-carousel {
  display: block;
}

@media (width >= 40rem) {
  .about-us-pledge-section .pledge-cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .about-us-pledge-section .pledge-carousel {
    display: none;
  }
}

@media (width >= 64rem) {
  .about-us-pledge-section .pledge-cards {
    gap: calc(var(--spacing) * 6);
  }
}

@media (min-width: 370px) and (max-width: 639px) {
  .range-height-section {
    height: auto;
    min-height: 800px;
    overflow: hidden;
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const track = document.getElementById('pledgeTrack-{{ section.id }}');
  if (!track) return;

  function setPledgeScrollSpeed() {
    if (window.innerWidth >= 640) return;

    requestAnimationFrame(() => {
      const half = track.scrollWidth / 2;
      const speed = 45;
      const duration = half / speed;

      track.style.animation = 'none';
      track.offsetHeight;
      track.style.setProperty('--scroll-duration', `${duration}s`);
      track.style.setProperty('--scroll-delay', '0s');
      track.style.animation = '';
    });
  }

  function detectCenterCard() {
    if (window.innerWidth >= 640) return;

    const cards = track.querySelectorAll('.pledge-scroll-card');
    const viewportCenter = window.innerWidth / 2;

    cards.forEach(card => {
      const rect = card.getBoundingClientRect();
      const cardCenter = rect.left + rect.width / 2;
      const distance = Math.abs(viewportCenter - cardCenter);
      const activationRange = rect.width * 0.25;

      card.classList.toggle('is-center', distance < activationRange);
    });

    requestAnimationFrame(detectCenterCard);
  }

  setPledgeScrollSpeed();
  detectCenterCard();
  window.addEventListener('resize', setPledgeScrollSpeed);
});
</script>

{% schema %}
{
  "name": "Pledge Banner About Us 2",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto superior (eyebrow)",
      "default": "Our Zero B.S. Pledge"
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Título",
      "default": "<p>Fourteen years ofcuration, decades of tradition.</p>"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Texto pequeño"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen 1"
    },
    {
      "type": "image_picker",
      "id": "image2",
      "label": "Imagen 2"
    },
    {
      "type": "image_picker",
      "id": "image3",
      "label": "Imagen 3"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Imagen de fondo"
    }

  ],
  "presets": [
    {
      "name": "Pledge Banner About Us 2"
    }
  ]
}
{% endschema %}
