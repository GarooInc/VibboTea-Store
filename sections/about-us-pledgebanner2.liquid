<section class="about-us-pledge-section full-width flex flex-col font-bricolage relative range-height-section">
  <div
    class="pledge-hero relative w-full min-h-[420px] md:min-h-[520px] lg:min-h-[580px]
           px-6 lg:px-28 md:py-20 py-10
           bg-[#FFF4DA] bg-cover bg-center bg-no-repeat"
    style="
      {% if section.settings.bg_image %}
        background-image: url('{{ section.settings.bg_image | image_url: width: 2000 }}');
      {% endif %}">
    <div class="absolute inset-0 bg-black opacity-30"></div>

    <div class="pledge-hero-copy relative z-10">
      {% if section.settings.eyebrow != blank %}
        <p class="text-5xl md:text-7xl sm:text-5xl mx-auto font-bold text-white">
          {{ section.settings.eyebrow }}
        </p>
      {% endif %}

      <div class="w-full flex justify-end">
        {% if section.settings.title != blank %}
          <h2 class="text-2xl md:text-3xl sm:text-3xl font-bold w-full
            text-right tracking-tight text-white max-w-2xl sm:max-w-md md:max-w-2xl pt-10">
            {{ section.settings.title }}
          </h2>
        {% endif %}
      </div>
    </div>

    <div class="pledge-carousel sm:hidden relative z-10 w-full px-4 pt-16 pb-4">
      <div class="carousel-wrapper-{{ section.id }} overflow-hidden rounded-xl">
        <div class="carousel-track flex transition-transform duration-300 ease-in-out">
          {% if section.settings.image %}
            <div class="carousel-slide min-w-full bg-white rounded-xl">
              <img
                src="{{ section.settings.image | image_url: width: 1200 }}"
                alt="Imagen 1"
                class="w-full h-[300px] object-contain object-center"
                width="{{ section.settings.image.width }}"
                height="{{ section.settings.image.height }}"
                loading="lazy"
              >
            </div>
          {% endif %}

          {% if section.settings.image2 %}
            <div class="carousel-slide min-w-full bg-white rounded-xl">
              <img
                src="{{ section.settings.image2 | image_url: width: 1200 }}"
                alt="Imagen 2"
                class="w-full h-[300px] object-contain object-center"
                width="{{ section.settings.image2.width }}"
                height="{{ section.settings.image2.height }}"
                loading="lazy"
              >
            </div>
          {% endif %}

          {% if section.settings.image3 %}
            <div class="carousel-slide min-w-full bg-white rounded-xl">
              <img
                src="{{ section.settings.image3 | image_url: width: 1200 }}"
                alt="Imagen 3"
                class="w-full h-[300px] object-contain object-center"
                width="{{ section.settings.image3.width }}"
                height="{{ section.settings.image3.height }}"
                loading="lazy"
              >
            </div>
          {% endif %}
        </div>
      </div>

      <div class="flex justify-center gap-2 mt-4">
        <button class="carousel-dot-{{ section.id }} w-2 h-2 rounded-full bg-gray-400 transition-all duration-300" data-index="0"></button>
        <button class="carousel-dot-{{ section.id }} w-2 h-2 rounded-full bg-gray-400 transition-all duration-300" data-index="1"></button>
        <button class="carousel-dot-{{ section.id }} w-2 h-2 rounded-full bg-gray-400 transition-all duration-300" data-index="2"></button>
      </div>
    </div>
  </div>

  <div class="pledge-cards relative z-20 px-5 lg:px-20">
    <div class="pledge-card flex items-center justify-center rounded-xl bg-white p-5 md:p-6 h-[320px] md:h-[400px]">
      <img
        src="{{ section.settings.image | image_url: width: 1200 }}"
        alt="Imagen 1"
        class="w-full h-auto max-h-[280px] md:max-h-[360px] object-contain object-center"
        width="{{ section.settings.image.width }}"
        height="{{ section.settings.image.height }}"
        loading="lazy"
      >
    </div>

    <div class="pledge-card flex items-center justify-center rounded-xl bg-white p-5 md:p-6 h-[320px] md:h-[400px]">
      <img
        src="{{ section.settings.image2 | image_url: width: 1200 }}"
        alt="Imagen 2"
        class="w-full h-auto max-h-[280px] md:max-h-[360px] object-contain object-center"
        width="{{ section.settings.image2.width }}"
        height="{{ section.settings.image2.height }}"
        loading="lazy"
      >
    </div>

    <div class="pledge-card flex items-center justify-center rounded-xl bg-white p-5 md:p-6 h-[320px] md:h-[400px]">
      <img
        src="{{ section.settings.image3 | image_url: width: 1200 }}"
        alt="Imagen 3"
        class="w-full h-auto max-h-[280px] md:max-h-[360px] object-contain object-center"
        width="{{ section.settings.image3.width }}"
        height="{{ section.settings.image3.height }}"
        loading="lazy"
      >
    </div>
  </div>

  {% if section.settings.text != blank %}
    <div class="pledge-text bg-white relative z-0 w-full flex justify-center pb-10 md:pb-16 px-4 text-center">
      <div class="max-w-2xl md:max-w-6xl text-xl sm:text-3xl md:text-4xl text-black">
        {{ section.settings.text }}
      </div>
    </div>
  {% endif %}
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const track = document.querySelector('.carousel-wrapper-{{ section.id }} .carousel-track');
  const dots = document.querySelectorAll('.carousel-dot-{{ section.id }}');
  let currentIndex = 0;
  let autoplayInterval;

  function updateCarousel(index) {
    if (!track) return;

    currentIndex = index;
    track.style.transform = `translateX(-${currentIndex * 100}%)`;

    dots.forEach((dot, i) => {
      if (i === currentIndex) {
        dot.classList.remove('bg-gray-400');
        dot.classList.add('bg-black', 'w-6');
      } else {
        dot.classList.remove('bg-black', 'w-6');
        dot.classList.add('bg-gray-400');
      }
    });
  }

  function startAutoplay() {
    autoplayInterval = setInterval(() => {
      currentIndex = (currentIndex + 1) % dots.length;
      updateCarousel(currentIndex);
    }, 3000);
  }

  function stopAutoplay() {
    clearInterval(autoplayInterval);
  }

  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      stopAutoplay();
      updateCarousel(parseInt(dot.dataset.index));
      startAutoplay();
    });
  });

  let startX = 0;
  let isDragging = false;

  if (track) {
    track.addEventListener('touchstart', (e) => {
      startX = e.touches[0].clientX;
      isDragging = true;
      stopAutoplay();
    });

    track.addEventListener('touchmove', (e) => {
      if (!isDragging) return;
      const currentX = e.touches[0].clientX;
      const diff = startX - currentX;

      if (Math.abs(diff) > 50) {
        if (diff > 0 && currentIndex < dots.length - 1) {
          currentIndex++;
        } else if (diff < 0 && currentIndex > 0) {
          currentIndex--;
        }
        updateCarousel(currentIndex);
        isDragging = false;
      }
    });

    track.addEventListener('touchend', () => {
      isDragging = false;
      startAutoplay();
    });
  }

  updateCarousel(0);
  startAutoplay();
});
</script>

<style>
.about-us-pledge-section .pledge-cards {
  display: none;
  gap: calc(var(--spacing) * 5);
  margin-top: calc(var(--spacing) * -40);
}

.about-us-pledge-section .pledge-text {
  padding-top: calc(var(--spacing) * 10);
}

@media (width >= 40rem) {
  .about-us-pledge-section .pledge-cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: calc(var(--spacing) * -50);
  }

  .about-us-pledge-section .pledge-text {
    padding-top: calc(var(--spacing) * 52);
  }
}

@media (width >= 64rem) {
  .about-us-pledge-section .pledge-cards {
    gap: calc(var(--spacing) * 6);
    margin-top: calc(var(--spacing) * -55);
  }

  .about-us-pledge-section .pledge-text {
    padding-top: calc(var(--spacing) * 56);
  }
}

@media (width < 40rem) {
  .about-us-pledge-section .pledge-carousel {
    display: block;
  }
}

@media (width >= 40rem) {
  .about-us-pledge-section .pledge-carousel {
    display: none;
  }
}

@media (min-width: 370px) and (max-width: 639px) {
  .range-height-section {
    height: auto;
    min-height: 800px;
    overflow: hidden;
  }
}
</style>

{% schema %}
{
  "name": "Pledge Banner About Us 2",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto superior (eyebrow)",
      "default": "Our Zero B.S. Pledge"
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Título",
      "default": "<p>Fourteen years ofcuration, decades of tradition.</p>"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Texto pequeño"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen 1"
    },
    {
      "type": "image_picker",
      "id": "image2",
      "label": "Imagen 2"
    },
    {
      "type": "image_picker",
      "id": "image3",
      "label": "Imagen 3"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Imagen de fondo"
    }

  ],
  "presets": [
    {
      "name": "Pledge Banner About Us 2"
    }
  ]
}
{% endschema %}
