<section class="roots-section full-width flex flex-col font-bricolage relative z-10 bg-white">
  <div class="w-full flex flex-col px-6 md:px-12 lg:px-24 md:pt-6 md:py-15 py-15 pb-10 md:pb-14">

    <div class="roots-copy-grid">
      {% if section.settings.title != blank %}
        <div class="roots-title-wrap">
          <h2 class="roots-title text-6xl md:text-7xl font-semibold w-full text-left
            tracking-tight text-black md:pt-4">{{ section.settings.title }}</h2>
        </div>
      {% endif %}

      {% if section.settings.text1 != blank %}
        <div class="roots-text-primary lg:text-4xl text-2xl font-light text-neutral-800">
          {{ section.settings.text1 }}
        </div>
      {% endif %}

      {% if section.settings.eyebrow != blank %}
        <div class="roots-eyebrow-wrap">
          <p class="roots-eyebrow lg:text-3xl text-xl font-light text-black leading-relaxed">
            {{ section.settings.eyebrow }}
          </p>
        </div>
      {% endif %}

      {% if section.settings.text2 != blank %}
        <div class="roots-text-secondary lg:text-3xl text-xl font-medium text-neutral-800">
          {{ section.settings.text2 }}
        </div>
      {% endif %}
    </div>
  </div>

  {% if section.settings.image %}
    <div class="w-full">
      <img
        src="{{ section.settings.image | image_url }}"
        alt=""
        class="zero-bs-image"
        width="{{ section.settings.image.width }}"
        height="{{ section.settings.image.height }}">
    </div>
  {% endif %}
</section>

<style>
  .roots-section .roots-copy-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 2rem;
  }

  .roots-section .roots-title p,
  .roots-section .roots-text-primary p,
  .roots-section .roots-text-secondary p {
    margin: 0;
  }

  .roots-section .roots-title {
    max-width: 11ch;
    line-height: 0.95;
    text-wrap: balance;
  }

  .roots-section .roots-eyebrow {
    max-width: 32ch;
    line-height: 1.2;
    text-wrap: balance;
  }

  .roots-section .roots-text-primary {
    line-height: 1.05;
    text-wrap: balance;
  }

  .roots-section .roots-text-secondary {
    line-height: 1.1;
  }

  @media (min-width: 768px) {
    .roots-section .roots-copy-grid {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      grid-template-rows: auto auto;
      column-gap: clamp(2rem, 5vw, 4.5rem);
      row-gap: clamp(2.5rem, 4vw, 3.5rem);
      align-items: start;
    }

    .roots-section .roots-title-wrap {
      grid-column: 1;
      grid-row: 1;
    }

    .roots-section .roots-text-primary {
      grid-column: 2;
      grid-row: 1;
      align-self: start;
      justify-self: start;
      max-width: 24ch;
      padding-top: 0.25rem;
    }

    .roots-section .roots-eyebrow-wrap {
      grid-column: 1;
      grid-row: 2;
      align-self: start;
    }

    .roots-section .roots-text-secondary {
      grid-column: 2;
      grid-row: 2;
      align-self: end;
      justify-self: end;
      width: max-content;
      max-width: 100%;
      text-align: right;
    }

    .roots-section .roots-text-secondary,
    .roots-section .roots-text-secondary p {
      white-space: nowrap !important;
      text-wrap: nowrap !important;
      overflow-wrap: normal !important;
      word-break: normal !important;
    }
  }

  @media (max-width: 767px) {
    .roots-section .roots-copy-grid {
      gap: 2.75rem;
    }

    .roots-section .roots-title {
      max-width: 10ch;
    }

    .roots-section .roots-eyebrow {
      max-width: 30ch;
      font-size: clamp(1rem, 4.2vw, 1.25rem);
    }

    .roots-section .roots-text-primary,
    .roots-section .roots-text-secondary {
      font-size: clamp(1.35rem, 5.8vw, 1.55rem);
      line-height: 1.1;
      text-align: right;
      margin-left: auto;
      max-width: 31ch;
    }

    .roots-section .roots-text-secondary,
    .roots-section .roots-text-secondary p {
      white-space: normal;
      text-wrap: balance;
      overflow-wrap: break-word;
    }
  }
</style>

{% schema %}
{
  "name": "Pledge Banner About Us 1",
  "settings": [
    {
      "type": "richtext",
      "id": "title",
      "label": "Título",
      "default": "<p>Fourteen years ofcuration, decades of tradition.</p>"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto superior (eyebrow)",
      "default": "Our Zero B.S. Pledge"
    },
    {
      "type": "richtext",
      "id": "text1",
      "label": "Texto 1"
    },
    {
      "type": "richtext",
      "id": "text2",
      "label": "Texto 2"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen"
    }
  ],
  "presets": [
    {
      "name": "Pledge Banner About Us 1"
    }
  ]
}
{% endschema %}
