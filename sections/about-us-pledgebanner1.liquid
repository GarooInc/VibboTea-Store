<section class="roots-section full-width flex flex-col font-bricolage relative z-10 bg-white">
  <div class="w-full flex flex-col px-6 lg:px-28 md:pt-10 md:py-15 py-15 pb-10 md:pb-14">

    <div class="w-full flex justify-start">
      {% if section.settings.title != blank %}
        <h2 class="text-6xl md:text-7xl font-semibold w-full text-left
          tracking-tight text-black max-w-2xl md:pt-4">{{ section.settings.title }}</h2>
      {% endif %}
    </div>

    {% if section.settings.eyebrow != blank %}
      <div class="w-full md:pt-10 pt-6">
        <p class="max-w-4xl lg:text-3xl text-xl font-light text-black leading-relaxed">
          {{ section.settings.eyebrow }}
        </p>
      </div>
    {% endif %}

    {% if section.settings.text1 != blank or section.settings.text2 != blank %}
      <div class="w-full md:pt-6 pt-4 flex flex-col gap-2">
        {% if section.settings.text1 != blank %}
          <div class="max-w-xl lg:text-4xl text-2xl font-light text-neutral-800">
            {{ section.settings.text1 }}
          </div>
        {% endif %}

        {% if section.settings.text2 != blank %}
          <div class="max-w-md lg:text-4xl text-2xl font-medium text-neutral-800">
            {{ section.settings.text2 }}
          </div>
        {% endif %}
      </div>
    {% endif %}
  </div>

  {% if section.settings.image %}
    <div class="w-full">
      <img
        src="{{ section.settings.image | image_url }}"
        alt=""
        class="zero-bs-image"
        width="{{ section.settings.image.width }}"
        height="{{ section.settings.image.height }}">
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Pledge Banner About Us 1",
  "settings": [
    {
      "type": "richtext",
      "id": "title",
      "label": "Título",
      "default": "<p>Fourteen years ofcuration, decades of tradition.</p>"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto superior (eyebrow)",
      "default": "Our Zero B.S. Pledge"
    },
    {
      "type": "richtext",
      "id": "text1",
      "label": "Texto 1"
    },
    {
      "type": "richtext",
      "id": "text2",
      "label": "Texto 2"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen"
    }
  ],
  "presets": [
    {
      "name": "Pledge Banner About Us 1"
    }
  ]
}
{% endschema %}
