
{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div 
class="section-{{ section.id }}-padding w-screen min-h-[80vh] bg-[#FFF9E8] flex flex-col-reverse md:flex-row justify-between"
style="width: 100vw; margin-left: calc(50% - 50vw);"
>

    <div class="w-full md:w-1/2 flex justify-start items-end pt-10">
        <div class="relative inline-block">
  
            <img 
                src="{{ section.settings.imagen2 | image_url: width: 600 }}" 
                alt="Imagen 2"
                class="pl-[11vw] pb-10"
            >
            <img 
                src="{{ section.settings.imagen | image_url: width: 400 }}" 
                alt="Imagen 1"
                class="absolute left-0 bottom-0"
            >

            </div>
    </div>


    <div class="w-full md:w-1/2 flex justify-left items-center  pt-15 pr-30">
        <div class="text-black text-[2vw] font-bricolage">
            {{ section.settings.page_descripction }}
        </div>
    </div>


</div>




{% schema %}
{
  "name": "Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "imagen",
      "label": "Image"
    },
    {
      "type": "image_picker",
      "id": "imagen2",
      "label": "Image2"
    },
    {
      "type": "richtext",
      "id": "page_descripction",
      "label": "Page Descripction",
      "default": "<p>Workers y and Farmers</p>"
    },
    {
      "type": "header",
      "content": "Margen para Computadora (PC)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Margen para Móvil"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Banner",
    }
  ]
}
{% endschema %}
