{% assign padding_top = section.settings.margin_top_image | default: 50 %}
<section id="{{ section.settings.id_section }}" style="position: relative; z-index: 20;">
<div class="w-full bg-white py-10 md:py-20 flex flex-col items-center">
  <div class="md:min-w-[90vw] min-w-sm mx-auto text-center md:px-4 px-5">

    {% assign img_align = section.settings.image_alignment | default: 'right' %}
    {% assign target_w = section.settings.image_target_width | default: 800 %}
    {% assign target_h_default = section.settings.image_target_height | default: 533 %}
    {% assign auto_size = section.settings.image_auto_size %}

    {% if section.settings.image1 %}
      {% assign orig_w = section.settings.image1.width | default: 0 %}
      {% assign orig_h = section.settings.image1.height | default: 0 %}
      {% if auto_size and orig_w > 0 and orig_h > 0 %}
        {% assign target_h = orig_h | times: target_w | divided_by: orig_w %}
      {% else %}
        {% assign target_h = target_h_default %}
      {% endif %}
    {% endif %}

    <!-- Header: imagen + título/subtítulo lado a lado en desktop -->
    <div class="w-full flex items-center gap-8 mb-10">
      {% if section.settings.image1 %}
        <div class="hidden md:block flex-shrink-0 w-48">
          <img
            src="{{ section.settings.image1 | image_url: width: target_w }}"
            alt="{{ section.settings.title }}"
            class="w-full object-contain"
            width="{{ target_w }}"
            height="{{ target_h }}"
          >
        </div>
      {% endif %}
      <div class="flex-1 text-center">
        {% if section.settings.title != blank %}
          <h2 class="text-3xl md:text-5xl font-semibold mb-4 font-bricolage">
            {{ section.settings.title }}
          </h2>
        {% endif %}
        <p class="text-xl">
          {{ section.settings.text_faq }}
        </p>
      </div>
    </div>

    <div class="w-full text-left">
      {% for block in section.blocks %}
      <div class="w-full pb-5" {{ block.shopify_attributes }}>
        <div
          class="faq-card border border-gray-300 rounded-xl px-5 py-5 cursor-pointer"
          data-faq
        >
          <div class="flex items-center justify-between">
            <h3 class="md:text-2xl font-semibold font-bricolage text-gray-800 text-left">
              {{ block.settings.question }}
            </h3>
            <button class="faq-toggle transition-transform duration-300" aria-label="toggle">
              {%- render 'arrow-faq1' -%}
            </button>
          </div>
          <div class="faq-content max-h-0 overflow-hidden transition-all duration-500">
            <p class="text-gray-700 mt-3 pr-10 text-left max-w-8/9 md:text-lg text-xs pt-3 md:pt-0">
              {{ block.settings.answer }}
            </p>
          </div>
        </div>
      </div>
      {% endfor %}
    </div>

    {% if section.settings.image1 %}
    <div class="md:hidden flex justify-end mt-8">
      <img
        src="{{ section.settings.image1 | image_url: width: 400 }}"
        alt="{{ section.settings.title }}"
        class="w-40 object-cover"
        width="400"
        height="400"
      >
    </div>
    {% endif %}

  </div>
</div>
</section>


<script>
  document.addEventListener("DOMContentLoaded", () => {
    const faqs = document.querySelectorAll("[data-faq]");

    faqs.forEach(faq => {
      const toggle = faq.querySelector(".faq-toggle");
      const content = faq.querySelector(".faq-content");

      faq.addEventListener("click", () => {
        const isOpen = content.style.maxHeight && content.style.maxHeight !== "0px";

        if (isOpen) {
          content.style.maxHeight = "0px";
          toggle.style.transform = "rotate(0deg)";
        } else {
          content.style.maxHeight = content.scrollHeight + "px";
          toggle.style.transform = "rotate(180deg)";
        }
      });
    });
  });
</script>


{% schema %}
{
  "name": "FAQ",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título principal",
      "default": "Preguntas frecuentes"
    },
    {
      "type": "text",
      "id": "id_section",
      "label": "Nombre de la seccion",
      "default": "#faqContact"
    },
    {
      "type": "textarea",
      "id": "text_faq",
      "label": "Texto secundiario",
      "default": "Read below for a good time."
    },
    {
     "type": "image_picker", 
     "id": "image1", 
      "label": "Image1"
    },
    {
      "type": "select",
      "id": "image_alignment",
      "label": "Alineación de la imagen",
      "options": [
        { "value": "left", "label": "Izquierda" },
        { "value": "right", "label": "Derecha" }
      ],
      "default": "right"
    },
  
   
    {
      "type": "number",
      "id": "margin_top_image",
      "label": "Padding por deceto (px)",
      "default": 50
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "Pregunta",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Pregunta"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Respuesta"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ"
    }
  ]
}
{% endschema %}
