<div 
class="w-full md:min-h-400px bg-[#F5F3F3] flex flex-col justify-between md:pb-10 lg:pb-20 relative px-[2vw] pb-10"
style="width: 100vw; margin-left: calc(50% - 50vw);"
>

    <!-- TÍTULO -->
    <div class="w-full flex md:justify-start md:items-start md:text-left text-center justify-center px-5 lg:px-20 md:px-10 lg:pt-20 md:pt-15 pt-10">
        <div class="text-black text-4xl xl:text-6xl font-bricolage font-semibold leading-[1.1]">
            {{ section.settings.title | newline_to_br }}
        </div>
    </div>

    <!-- VERSION MOBILE SOCIALS -->
    <div class="md:hidden flex flex-col justify-center items-center py-2">

      <div class="h-12 flex items-center justify-center">
        <p class="text-black font-bricolage text-center text-[3.5vw]"> 
          {{ section.settings.text_socials }}
        </p>
      </div>

      <div class="flex pl-2 gap-4">
        <div class="flex justify-end bg-black rounded-full">
            <a href="{{ section.settings.facebook_url }}" target="_blank" class="scale-70">
              {%- render 'fb' -%}
            </a>
        </div>
        <div class="flex justify-end bg-black rounded-full text-white">
            <a href="{{ section.settings.instagram_url }}" target="_blank" class="scale-70">
              {%- render 'ig' -%}
            </a>
        </div>
        <div class="flex justify-end bg-black rounded-full">
            <a href="{{ section.settings.tiktok_url }}" target="_blank" class="scale-80">
              {%- render 'tiktok' -%}
            </a>
        </div>
      </div>
    </div>


    <!-- SLIDER -->
    <div class="w-full flex justify-center items-center relative md:px-5">

        <!-- Flecha izquierda -->
        <button class="prevBtn absolute left-4 md:left-5 top-1/2 -translate-y-1/2 z-10 w-15 h-15 rounded-full md:flex hidden items-center justify-center">
          {%  render 'arrow-slidder2'  %}
        </button>

        <div class="socialsSlider overflow-hidden w-full pt-10 md:px-10 px-5">
            <div class="sliderTrack flex transition-transform duration-300 ease-out">

                {% for block in section.blocks %}
                  <div 
                    class="slide-item min-w-full md:min-w-[33.3333%] p-5"
                    {{ block.shopify_attributes }}
                  >
                    {% assign remainder = forloop.index0 | modulo: 2 %}
                    
                    <div class="
                      relative w-full
                      {% if remainder == 0 %}
                        md:-pt-16
                      {% else %}
                        md:pt-16
                      {% endif %}
                    ">
                      <img 
                        src="{{ block.settings.image | img_url: '2000x2000' }}" 
                        alt="Imagen {{ forloop.index }}"
                        class="w-full h-full object-cover rounded-xl"
                        width="{{ block.settings.image.width }}"
                        height="{{ block.settings.image.height }}"
                      >
                    </div>
                  </div>
                {% endfor %}

            </div>
        </div>

        <!-- Flecha derecha -->
        <button class="nextBtn absolute right-4 md:right-5 top-1/2 -translate-y-1/2 z-10 w-15 h-15 rounded-full md:flex hidden items-center justify-center">
          {%  render 'arrow-slidder'  %}
        </button>

    </div>


    <!-- VERSION DESKTOP SOCIALS -->
    <div class="hidden md:flex flex-col md:flex-row w-full justify-center items-center mt-5 md:mt-0 py-5">

        <div class="flex pl-2 gap-5">
            <div class="flex justify-end bg-black rounded-full">
                <a href="{{ section.settings.facebook_url }}" target="_blank" class="scale-70">
                  {%- render 'fb' -%}
                </a>
            </div>
            <div class="flex justify-end bg-black rounded-full px-1 text-white">
                <a href="{{ section.settings.instagram_url }}" target="_blank" class="scale-70">
                  {%- render 'ig' -%}
                </a>
            </div>
            <div class="flex justify-end bg-black rounded-full">
                <a href="{{ section.settings.tiktok_url }}" target="_blank" class="scale-80">
                  {%- render 'tiktok' -%}
                </a>
            </div>
        </div>

        <div class="h-12 w-auto pl-4 pr-0 flex items-center justify-between">
          <p class="text-black text-[4vw] md:text-xl font-bricolage flex-1 px-3">
            {{ section.settings.social }}
          </p>
        </div>

    </div>

</div>

<script>
document.addEventListener("DOMContentLoaded", function () {

  const slider = document.querySelector(".socialsSlider");
  if (!slider) return;

  const track = slider.querySelector(".sliderTrack");
  const slides = slider.querySelectorAll(".slide-item");
  const prevBtn = slider.parentElement.querySelector(".prevBtn");
  const nextBtn = slider.parentElement.querySelector(".nextBtn");

  let currentIndex = 0;

  function getVisibleSlides() {
    return window.innerWidth >= 768 ? 3 : 1;
  }

  function getSlideWidth() {
    return slides[0].offsetWidth;
  }

  function getMaxIndex() {
    return slides.length - getVisibleSlides();
  }

  function updateSlider() {
    const slideWidth = getSlideWidth();
    track.style.transform = `translateX(-${currentIndex * slideWidth}px)`;
  }

  function goNext() {
    if (currentIndex >= getMaxIndex()) {
      currentIndex = 0;
    } else {
      currentIndex++;
    }
    updateSlider();
  }

  function goPrev() {
    if (currentIndex <= 0) {
      currentIndex = getMaxIndex();
    } else {
      currentIndex--;
    }
    updateSlider();
  }

  nextBtn.addEventListener("click", goNext);
  prevBtn.addEventListener("click", goPrev);

  // Swipe mobile
  let startX = 0;
  let endX = 0;

  slider.addEventListener("touchstart", e => {
    startX = e.touches[0].clientX;
  });

  slider.addEventListener("touchend", e => {
    endX = e.changedTouches[0].clientX;
    handleSwipe();
  });

  function handleSwipe() {
    if (startX - endX > 50) {
      goNext();
    }
    if (endX - startX > 50) {
      goPrev();
    }
  }

  window.addEventListener("resize", () => {
    currentIndex = 0;
    updateSlider();
  });

});
</script>


{% schema %}
{
  "name": "Section socials",
  "settings": [
    {
      "type": "textarea",
      "id": "title",
      "label": "Title",
      "default": "Title"
    },
    {
      "type": "text",
      "id": "text_socials",
      "label": "Texto",
      "default": "Follow our socials, never miss a brew."
    },
    {
      "type": "text",
      "id": "social",
      "label": "Red social",
      "default": "@drinkvvibbo"
    },
    {
      "type": "url",
      "id": "instagram-url",
      "label": "URL"
    },
    
    
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "Tiktok URL"
    },
    
    
    
  ],
  "blocks": [
  {
    "type": "image",
    "name": "Imagen",
    "settings": [
      {
        "type": "image_picker",
        "id": "image",
        "label": "Imagen"
      }
    ]
  }
],
"max_blocks": 12,
  "presets": [
    {
      "name": "Section socials"
    }
  ]
}
{% endschema %}
