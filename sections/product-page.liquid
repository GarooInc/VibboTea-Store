<div class="grid grid-cols-1 md:grid-cols-2 gap-4 items-start
   md:px-5 md:py-10 md:pt-28 pt-32">

  {% if product %}
    {% assign current_variant = product.selected_or_first_available_variant %}

    {% if product.media.size > 1 %}

    <!-- DESKTOP: Imagen principal + grid de miniaturas abajo -->
    <div class="hidden md:flex flex-col gap-3 w-full min-w-0 overflow-hidden md:sticky md:top-28 md:self-start z-10">
      <div class="w-full rounded-xl overflow-hidden relative" id="mainImageDesktop">
        {% assign first_media = product.media[0] %}
        {% if first_media.media_type == "image" %}
          <img
            src="{{ first_media | image_url: width: 1200 }}"
            alt="{{ first_media.alt | escape }}"
            class="w-full h-auto block"
            id="mainDesktopImg"
            width="{{ first_media.width }}"
            height="{{ first_media.height }}"
          />
        {% elsif first_media.media_type == "video" %}
          <video autoplay loop muted playsinline class="w-full h-auto block" id="mainDesktopVideo">
            <source src="{{ first_media.sources[1].url }}" type="video/mp4">
          </video>
        {% endif %}
        <button class="absolute left-0 top-1/2 -translate-y-1/2 text-black px-3 py-2 cursor-pointer z-10" onclick="desktopPrev()">
          {% render 'arrow-slidder2' %}
        </button>
        <button class="absolute right-0 top-1/2 -translate-y-1/2 text-black px-3 py-2 cursor-pointer z-10" onclick="desktopNext()">
          {% render 'arrow-slidder' %}
        </button>
      </div>
      <div class="grid grid-cols-3 xl:grid-cols-4 w-full" style="gap: 8px;">
        {% for media in product.media %}
          {% assign is_video = false %}
          {% if media.media_type == "video" or media.media_type == "external_video" %}
            {% assign is_video = true %}
          {% endif %}
          <button
            class="desktop-thumb rounded-lg overflow-hidden border-2 transition-all duration-200 cursor-pointer {% if is_video %}col-span-2{% else %}aspect-square{% endif %} {% if forloop.first %}border-black opacity-100{% else %}border-transparent opacity-60{% endif %}"
            {% if is_video %}style="aspect-ratio: 2 / 1;"{% endif %}
            data-src="{{ media | image_url: width: 1200 }}"
            data-alt="{{ media.alt | escape }}"
            data-type="{{ media.media_type }}"
            {% if media.media_type == "video" %}data-video="{{ media.sources[1].url }}"{% endif %}
            {% if media.media_type == "external_video" %}data-video="{{ media.sources[0].url }}"{% endif %}
            aria-label="Ver imagen {{ forloop.index }}"
          >
            <img
              src="{{ media.preview_image | image_url: width: 400 }}"
              alt="{{ media.alt | escape }}"
              class="w-full h-full object-cover"
            />
          </button>
        {% endfor %}
      </div>
    </div>

    <!-- MOBILE: Carrusel -->
    <div class="md:hidden flex flex-col gap-3">

      <div class="relative w-full overflow-hidden rounded-xl" id="productSlider">

        <div class="flex transition-transform duration-500" id="sliderTrack">
          {% for media in product.media %}
            <div class="w-full h-full shrink-0 aspect-square overflow-hidden rounded-xl">
              {% if media.media_type == "image" %}
                <img
                  src="{{ media | image_url: width: 1200 }}"
                  alt="{{ media.alt | escape }}"
                  class="w-full h-full object-cover"
                  width="{{ media.width }}"
                  height="{{ media.height }}"
                />
              {% elsif media.media_type == "video" %}
                <video autoplay loop muted playsinline class="w-full h-full object-cover">
                  <source src="{{ media.sources[1].url }}" type="video/mp4">
                </video>
              {% elsif media.media_type == "external_video" %}
                {% if media.host == "youtube" %}
                  <iframe
                    src="https://www.youtube.com/embed/{{ media.external_id }}?autoplay=1&mute=1&loop=1&playlist={{ media.external_id }}&controls=0&modestbranding=1&rel=0"
                    class="w-full h-full" frameborder="0"
                    allow="autoplay; encrypted-media" allowfullscreen
                  ></iframe>
                {% elsif media.host == "vimeo" %}
                  <iframe
                    src="https://player.vimeo.com/video/{{ media.external_id }}?autoplay=1&muted=1&loop=1&background=1&controls=0"
                    class="w-full h-full" frameborder="0"
                    allow="autoplay; fullscreen" allowfullscreen
                  ></iframe>
                {% endif %}
              {% endif %}
            </div>
          {% endfor %}
        </div>

        <!-- BOTONES -->
        <button class="absolute left-0 top-1/2 -translate-y-1/2 text-black px-3 py-2 cursor-pointer" onclick="slidePrev()">
          {% render 'arrow-slidder2' %}
        </button>
        <button class="absolute right-0 top-1/2 -translate-y-1/2 text-black px-3 py-2 cursor-pointer" onclick="slideNext()">
          {% render 'arrow-slidder' %}
        </button>
      </div>

      <!-- MINIATURAS -->
      <div class="flex gap-2 overflow-x-auto pb-1 justify-center" id="thumbnailStrip">
        {% for media in product.media %}
          <button
            class="thumbnail-btn shrink-0 w-18 h-18 rounded-lg overflow-hidden border-2 transition-all duration-200 cursor-pointer {% if forloop.first %}border-black opacity-100{% else %}border-transparent opacity-60{% endif %}"
            onclick="goToSlide({{ forloop.index0 }})"
            aria-label="Ver imagen {{ forloop.index }}"
          >
            <img
              src="{{ media.preview_image | image_url: width: 200 }}"
              alt="{{ media.alt | escape }}"
              class="w-full h-full object-cover"
            />
          </button>
        {% endfor %}
      </div>

    </div>

    {% else %}
      <div class="product-media w-full justify-center">
        {% if product.featured_media %}
          <img 
            src="{{ product.featured_media | image_url: width: 1200 }}"
            alt="{{ product.featured_media.alt | escape }}"
            class="w-full h-auto object-cover rounded-xl"
            width="{{ product.featured_media.width }}"
            height="{{ product.featured_media.height }}"
          />
        {% endif %}
      </div>
    {% endif %}


      <div class="product-info w-full flex flex-col justify-between items-start h-auto min-w-0">
        <div>

          <!-- Judge.me reviews -->
          <div class="mb-4 flex justify-left" style="margin-top: 24px;">
            <div class='jdgm-widget jdgm-preview-badge jdgm--done' data-id='{{ product.id }}'
              style="font-size: 1.3rem;">
              {{ product.metafields.judgeme.badge }}
            </div>
          </div>


          <h1 class="text-3xl md:text-4xl font-bricolage font-medium text-black mb-4">
            {{ product.title }}
          </h1>


        <div id="priceWrapper" class="py-4 flex flex-col gap-3 transition-all duration-300 w-full">
          {% if section.settings.kickstarter_price %}
            <span class="text-md md:text-xl text-red-700 font-bricolage uppercase">
              {{ section.settings.text_kickstarter }}
            </span>

            <div id="priceDisplay" class="flex items-start gap-3 transition-all duration-300">
              <div>
                <span class="text-3xl md:text-4xl text-black">
                  {{ current_variant.price | money }}
                </span>
                <span class="text-2xl md:text-3xl text-gray-400 line-through">
                  {{ current_variant.compare_at_price | money }}
                </span>
              </div>
              <span
                class="text-xs md:text-lg font-bricolage font-light p-1 px-3 rounded-xl flex mt-2"
                style="background-color: {{ section.settings.per_serving_bg_color }}; color: {{ section.settings.per_serving_text_color }};"
              >
                {{ section.settings.discount_text_kickstarter }}
              </span>
            </div>

            <p class="pt-1">{{ section.settings.discount_per_serving_kickstarter }}</p>

            <div id="countdown" class="text-red-700 text-md md:text-lg">
              {{ section.settings.timer_kickstarter }} <span id="timer"></span>
            </div>

            <!-- Descripción con widget embebido donde dice ProductDrop -->
            {% assign desc_parts = product.description | split: 'ProductDrop' %}
            <div class="text-sm text-black font-bricolage product-description md:pr-10">
              {{ desc_parts[0] }}
            </div>

            {% if section.settings.presentation_text != blank %}
              <div class="text-sm text-black font-bricolage md:pr-10">
                <strong class="block">Presentation</strong>
                {{ section.settings.presentation_text | newline_to_br }}
              </div>
            {% endif %}

            {% if section.settings.steeping_instructions_text != blank %}
              <div class="text-sm text-black font-bricolage md:pr-10">
                <strong class="block">Steeping instructions:</strong>
                {{ section.settings.steeping_instructions_text | newline_to_br }}
              </div>
            {% endif %}

            {% if desc_parts[1] != blank %}
              <div class="text-sm text-black font-bricolage product-description md:pr-10">
                {{ desc_parts[1] }}
              </div>
            {% endif %}

            {%- for block in section.blocks -%}
              {%- if block.type == '@app' -%}
                {% render block %}
              {%- endif -%}
            {%- endfor -%}

            <div class="w-full">
              <button
                type="button"
                id="addToCartKickstarter"
                {% unless current_variant.available %}disabled{% endunless %}
                class="flex items-center justify-center w-full rounded-3xl py-3
                      hover:opacity-70 transition-opacity disabled:opacity-50 cursor-pointer"
                style="background-color: {{ section.settings.per_serving_bg_color }}; color: {{ section.settings.per_serving_text_color }};"
              >
                <span class="font-bricolage xl:text-xl text-sm text-center uppercase font-light px-10">
                  {% if current_variant.available %}
                    {{ section.settings.text_kickstarter_button }}
                  {% else %}
                    {{ section.settings.sold_out_text }}
                  {% endif %}
                </span>
              </button>
            </div>

          {% else %}
            <div id="priceDisplay" class="flex items-center gap-4 transition-all duration-300">
              {% if current_variant.compare_at_price > current_variant.price %}
                <span class="text-2xl md:text-2xl text-gray-400 line-through">
                  {{ current_variant.compare_at_price | money }}
                </span>
                <span class="text-2xl md:text-3xl text-red-700 font-light">
                  {{ current_variant.price | money }}
                </span>
              {% else %}
                <span class="text-2xl md:text-3xl text-gray-700">
                  {{ current_variant.price | money }}
                </span>
              {% endif %}
            </div>
          {% endif %}
        </div>

        <!-- Variantes -->
        {% unless product.has_only_default_variant %}
          {% assign first_variant = product.selected_or_first_available_variant %}
          <p class="font-bricolage md:text-lg text-sm pt-3">Quantity:</p>
          <div class="w-full grid grid-cols-4 md:gap-4 gap-3 pt-5">
            {% for variant in product.variants %}
              {% assign parts = variant.title | split: '/' %}
              {% assign descount = parts[0] | strip %}
              {% assign cant = parts[1] | strip | remove: 'gr' | strip %}

              <div
                class="variant-option rounded-xl w-full h-full flex flex-col
                      cursor-pointer border border-gray-400
                      transition-all duration-300 overflow-hidden
                      {% if variant.id == first_variant.id %}ring-2 ring-black scale-105{% endif %}"
                data-variant-id="{{ variant.id }}"
                data-price="{{ variant.price | money }}"
                data-price-raw="{{ variant.price }}"
                data-compare="{{ variant.compare_at_price | money }}"
                data-compare-raw="{{ variant.compare_at_price }}"
              >
                <div class="w-full bg-gray-800 flex items-center justify-center h-15 md:h-14">
                  <p class="font-bricolage md:text-md text-xs text-center text-white px-2 leading-tight">
                    {{ descount }}
                  </p>
                </div>
                <div class="flex-1 w-full flex items-center justify-center py-2">
                  <p class="font-bricolage md:text-lg text-sm">{{ cant }}</p>
                </div>
              </div>
            {% endfor %}
          </div>
        {% endunless %}
      </div>

      {% unless section.settings.kickstarter_price %}
        <form id="addToCartForm" class="w-full py-4 items-end text-center mx-auto cursor-pointer">
          <input type="hidden" name="id" id="variantInput" value="{{ current_variant.id }}">
          <button
            type="submit"
            {% unless current_variant.available %}disabled{% endunless %}
            class="bg-gray-800 flex items-center justify-center w-full rounded-3xl py-3 
                  hover:opacity-70 transition-opacity disabled:opacity-50"
          >
            <span class="font-bricolage text-white xl:text-sm text-md uppercase font-light">
              {% if current_variant.available %}
                {{ section.settings.text_button }}
              {% else %}
                {{ section.settings.sold_out_text }}
              {% endif %}
            </span>
          </button>
        </form>
      {% endunless %}

      <div>
        <p class="text-sm text-gray-500 font-bricolage italic pb-20">
          {{ section.settings.disclaimer_kickstarter }}
        </p>
      </div>
    </div>

  {% else %}
    <div class="col-span-2 text-center text-sm text-gray-500">No product selected in section settings.</div>
  {% endif %}

</div>

<script>
  const variants = document.querySelectorAll('.variant-option');
  const priceWrapper = document.getElementById('priceWrapper');
  const variantInput = document.getElementById('variantInput');

  variants.forEach(option => {
    option.addEventListener('click', () => {
      variants.forEach(v => v.classList.remove('ring-2', 'ring-black', 'scale-105'));
      option.classList.add('ring-2', 'ring-black', 'scale-105');

      // Actualizar form normal (modo no-kickstarter)
      if (variantInput) variantInput.value = option.dataset.variantId;

      // Actualizar botón kickstarter
      const ksBtn = document.getElementById('addToCartKickstarter');
      if (ksBtn) ksBtn.dataset.variantId = option.dataset.variantId;

      const priceDisplay = document.getElementById('priceDisplay');
      if (priceDisplay) {
        priceDisplay.classList.add('opacity-0', 'translate-y-2');
        setTimeout(() => {
          const price = option.dataset.price;
          const compare = option.dataset.compare;
          if (compare && compare !== '') {
            priceDisplay.innerHTML = `
              <div>
                <span class="text-3xl md:text-4xl text-black">${price}</span>
                <span class="text-2xl md:text-3xl text-gray-400 line-through">${compare}</span>
              </div>
            `;
          } else {
            priceDisplay.innerHTML = `<span class="text-3xl md:text-4xl text-black">${price}</span>`;
          }
          priceDisplay.classList.remove('opacity-0', 'translate-y-2');
        }, 200);
      }
    });
  });

  // Add to Cart via Cart API para el botón kickstarter
  const ksBtn = document.getElementById('addToCartKickstarter');
  if (ksBtn) {
    // Guardar variant id inicial
    ksBtn.dataset.variantId = '{{ current_variant.id }}';
    const btnText = ksBtn.querySelector('span');

    // Re-habilitar si el navegador restaura la página desde caché
    window.addEventListener('pageshow', () => {
      ksBtn.disabled = false;
      if (btnText) btnText.textContent = ksBtn.dataset.originalText || '{{ section.settings.text_button }}';
    });

    ksBtn.addEventListener('click', async () => {
      const variantId = ksBtn.dataset.variantId;
      const originalText = btnText ? btnText.textContent.trim() : '';

      ksBtn.disabled = true;

      try {
        const res = await fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: parseInt(variantId), quantity: 1 })
        });

        if (res.ok) {
          ksBtn.disabled = false;
          if (typeof openCartDrawer === 'function') openCartDrawer();
        } else {
          const err = await res.json();
          btnText.textContent = err.description || 'Error';
          setTimeout(() => {
            btnText.textContent = originalText;
            ksBtn.disabled = false;
          }, 2000);
        }
      } catch (e) {
        btnText.textContent = 'Error';
        setTimeout(() => {
          btnText.textContent = originalText;
          ksBtn.disabled = false;
        }, 2000);
      }
    });
  }
</script>

<script>
  let currentSlide = 0;
  let autoplayInterval = null;

  function updateThumbnails(scrollToThumb = false) {
    const thumbs = document.querySelectorAll('.thumbnail-btn');
    thumbs.forEach((thumb, i) => {
      if (i === currentSlide) {
        thumb.classList.add('border-black', 'opacity-100');
        thumb.classList.remove('border-transparent', 'opacity-60');
        if (scrollToThumb) {
          thumb.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
        }
      } else {
        thumb.classList.remove('border-black', 'opacity-100');
        thumb.classList.add('border-transparent', 'opacity-60');
      }
    });
  }

  function goToSlide(index) {
    const track = document.getElementById("sliderTrack");
    currentSlide = index;
    track.style.transform = `translateX(-${currentSlide * 100}%)`;
    updateThumbnails(true);
  }

  function slideNext() {
    const track = document.getElementById("sliderTrack");
    const slides = track.children.length;
    currentSlide = (currentSlide + 1) % slides;
    track.style.transform = `translateX(-${currentSlide * 100}%)`;
    updateThumbnails();
  }

  function slidePrev() {
    const track = document.getElementById("sliderTrack");
    const slides = track.children.length;
    currentSlide = (currentSlide - 1 + slides) % slides;
    track.style.transform = `translateX(-${currentSlide * 100}%)`;
    updateThumbnails();
  }

  function startAutoplay() {
    autoplayInterval = setInterval(slideNext, 3500);
  }

  function stopAutoplay() {
    clearInterval(autoplayInterval);
  }

  const slider = document.getElementById('productSlider');
  if (slider) {
    slider.addEventListener('mouseenter', stopAutoplay);
    slider.addEventListener('mouseleave', startAutoplay);
    slider.addEventListener('touchstart', stopAutoplay, { passive: true });
    slider.addEventListener('touchend', startAutoplay, { passive: true });
    startAutoplay();
  }

  // Desktop grid: navegación principal
  const desktopThumbs = document.querySelectorAll('.desktop-thumb');
  const mainWrapper = document.getElementById('mainImageDesktop');
  let desktopIndex = 0;

  function desktopGoTo(index) {
    const thumbsArr = Array.from(desktopThumbs);
    desktopIndex = (index + thumbsArr.length) % thumbsArr.length;
    const btn = thumbsArr[desktopIndex];

    thumbsArr.forEach(b => {
      b.classList.remove('border-black', 'opacity-100');
      b.classList.add('border-transparent', 'opacity-60');
    });
    btn.classList.remove('border-transparent', 'opacity-60');
    btn.classList.add('border-black', 'opacity-100');

    const type = btn.dataset.type;
    if (type === 'video' || type === 'external_video') {
      let img = mainWrapper.querySelector('img');
      if (img) img.remove();
      let vid = mainWrapper.querySelector('video');
      if (!vid) {
        vid = document.createElement('video');
        vid.autoplay = true; vid.loop = true; vid.muted = true; vid.playsInline = true;
        vid.className = 'w-full h-auto block';
        mainWrapper.insertBefore(vid, mainWrapper.querySelector('button'));
      }
      vid.src = btn.dataset.video;
      vid.load(); vid.play();
    } else {
      let vid = mainWrapper.querySelector('video');
      if (vid) vid.remove();
      let img = mainWrapper.querySelector('img');
      if (!img) {
        img = document.createElement('img');
        img.className = 'w-full h-auto block';
        mainWrapper.insertBefore(img, mainWrapper.querySelector('button'));
      }
      img.src = btn.dataset.src;
      img.alt = btn.dataset.alt;
    }
  }

  function desktopNext() { desktopGoTo(desktopIndex + 1); }
  function desktopPrev() { desktopGoTo(desktopIndex - 1); }

  desktopThumbs.forEach((btn, i) => {
    btn.addEventListener('click', () => desktopGoTo(i));
  });
</script>

<script>
  if (document.getElementById("timer")) {
    function getEndOfDay() {
      const end = new Date();
      end.setHours(23, 59, 59, 999);
      return end.getTime();
    }

    const endTime = getEndOfDay();

    function updateCountdown() {
      const timerEl = document.getElementById("timer");
      if (!timerEl) return;

      const distance = endTime - new Date().getTime();
      if (distance <= 0) { location.reload(); return; }

      const h = Math.floor(distance / (1000 * 60 * 60));
      const m = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
      const s = Math.floor((distance % (1000 * 60)) / 1000);

      timerEl.innerHTML =
        String(h).padStart(2,'0') + ":" +
        String(m).padStart(2,'0') + ":" +
        String(s).padStart(2,'0');
    }

    setInterval(updateCountdown, 1000);
    updateCountdown();
  }
</script>

<script>
  const addToCartForm = document.getElementById('addToCartForm');
  if (addToCartForm) {
    addToCartForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const variantId = document.getElementById('variantInput').value;
      const btn = addToCartForm.querySelector('button[type="submit"]');
      const btnText = btn ? btn.querySelector('span') : null;
      const originalText = btnText ? btnText.textContent : '';

      if (btn) btn.disabled = true;

      const res = await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: parseInt(variantId), quantity: 1 })
      });

      if (res.ok) {
        if (btn) btn.disabled = false;
        if (typeof openCartDrawer === 'function') openCartDrawer();
      } else {
        if (btnText) btnText.textContent = 'Error';
        setTimeout(() => {
          if (btnText) btnText.textContent = originalText;
          if (btn) btn.disabled = false;
        }, 2000);
      }
    });
  }
</script>

{% schema %}
{
  "name": "Description product",
  "settings": [
    {
      "type": "text",
      "id": "text_button",
      "label": "Text button",
      "default": "ADD TO CART"
    },
    {
      "type": "text",
      "id": "sold_out_text",
      "label": "Sold out text",
      "default": "SOLD OUT"
    },
    {
      "type": "checkbox",
      "id": "kickstarter_price",
      "label": "Kickstarter price",
      "default": true
    },
    {
      "type": "richtext",
      "id": "text_kickstarter",
      "label": "Kickstarter text",
      "default": "<p>A DISCOUNTED KICKSTARTER PRICE NOW LIVE!</p>"
    },
    {
      "type": "text",
      "id": "text_kickstarter_button",
      "label": "Kickstarter button text",
      "default": "ADD DISCOUNT"
    },
    {
      "type": "text",
      "id": "discount_text_kickstarter",
      "label": "Discount text",
      "default": "20% OFF"
    },
    {
      "type": "text",
      "id": "discount_per_serving_kickstarter",
      "label": "Discount per serving text",
      "default": "$0.57 per serving"
    },
    {
      "type": "color",
      "id": "per_serving_bg_color",
      "label": "Per Serving Background Color",
      "default": "#f3f4f6"
    },
    {
      "type": "color",
      "id": "per_serving_text_color",
      "label": "Per Serving Text Color",
      "default": "#000000"
    },
    {
      "type": "text",
      "id": "timer_kickstarter",
      "label": "Timer text",
      "default": "SALES ENDS IN: "
    },
    {
      "type": "text",
      "id": "time_discount_kickstarter",
      "label": "Discount End Date (YYYY-MM-DD HH:MM:SS)",
      "default": "2026-02-27 23:59:59"
    },
    {
      "type": "url",
      "id": "kickstarter_link",
      "label": "Kickstarter link"
    },
    {
      "type": "textarea",
      "id": "disclaimer_kickstarter",
      "label": "Disclaimer Kickstarter text"
    },
    {
      "type": "textarea",
      "id": "presentation_text",
      "label": "Presentation text"
    },
    {
      "type": "textarea",
      "id": "steeping_instructions_text",
      "label": "Steeping instructions text"
    }
  ],
  "blocks": [{ "type": "@app" }],
  "presets": [{ "name": "Description product" }]
}
{% endschema %}