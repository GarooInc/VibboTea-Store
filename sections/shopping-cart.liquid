<div class="max-w-3xl mx-auto px-4 py-20 pt-40 font-bricolage">

  <h1 class="text-3xl md:text-4xl font-medium text-black mb-10">
    {{ 'cart.title' | t }}
  </h1>

  {% if cart.item_count == 0 %}
    <p class="text-gray-500 text-sm">Your cart is empty.</p>
    <a href="/collections/all" class="inline-block mt-6 text-sm underline text-black">Continue shopping</a>

  {% else %}
    <form action="{{ routes.cart_url }}" method="post">

      <div class="flex flex-col gap-6">
        {% for item in cart.items %}
          <div class="flex gap-4 items-center border-b border-gray-200 pb-6">

            <!-- Imagen -->
            <a href="{{ item.url }}" class="shrink-0">
              <img
                src="{{ item.image | image_url: width: 150 }}"
                alt="{{ item.image.alt | escape }}"
                class="w-24 h-24 object-cover rounded-lg"
                width="96" height="96"
              />
            </a>

            <!-- Info -->
            <div class="flex-1">
              <a href="{{ item.url }}" class="text-black font-medium text-sm md:text-base hover:underline">
                {{ item.product.title }}
              </a>
              {% unless item.variant.title == 'Default Title' %}
                <p class="text-xs text-gray-500 mt-1">{{ item.variant.title }}</p>
              {% endunless %}
              <p class="text-sm text-gray-700 mt-1">{{ item.price | money }}</p>

              <!-- Cantidad -->
              <div class="flex items-center gap-2 mt-3">
                <label for="qty_{{ item.key }}" class="text-xs text-gray-500">Qty:</label>
                <input
                  type="number"
                  name="updates[]"
                  id="qty_{{ item.key }}"
                  value="{{ item.quantity }}"
                  min="1"
                  class="w-14 border border-gray-300 rounded-lg text-center text-sm py-1"
                >
              </div>
            </div>

            <!-- Subtotal + eliminar -->
            <div class="flex flex-col items-end gap-3 shrink-0">
              <p class="text-sm font-medium text-black">{{ item.line_price | money }}</p>
              <a
                href="{{ item.url_to_remove }}"
                class="text-xs text-gray-400 hover:text-red-500 transition-colors underline"
              >
                Remove
              </a>
            </div>
          </div>
        {% endfor %}
      </div>

      <!-- Totales -->
      <div class="mt-8 flex flex-col items-end gap-4">
        <div class="flex justify-between w-full md:w-1/2">
          <span class="text-sm text-gray-500">Subtotal</span>
          <span class="text-sm font-medium text-black">{{ cart.total_price | money }}</span>
        </div>
        <p class="text-xs text-gray-400 text-right">Shipping and taxes calculated at checkout.</p>

        <div class="flex gap-3 w-full md:w-auto">
          <button
            type="submit"
            name="update"
            class="border border-gray-300 text-sm text-black rounded-3xl px-6 py-3 hover:opacity-70 transition-opacity"
          >
            Update cart
          </button>
          <button
            type="submit"
            name="checkout"
            class="bg-gray-800 text-white text-sm rounded-3xl px-8 py-3 hover:opacity-70 transition-opacity"
          >
            Checkout
          </button>
        </div>
      </div>

    </form>
  {% endif %}

</div>

{% schema %}
{
  "name": "Shopping cart",
  "settings": []
}
{% endschema %}