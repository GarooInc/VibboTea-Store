<div class="slider-facts-{{ section.id }} custom-slider-facts md:relative md:w-screen mx-auto "
style="margin-left: calc(50% - 50vw); margin-right: calc(50% - 50vw);">

  {% comment %} version desktop {% endcomment %}
  <div class="hidden md:block slides-wrapper md:relative w-full">
    {% for block in section.blocks %}
      {% assign img = block.settings.image_desktop %}
      <div class="slide absolute inset-0 {% if forloop.first %}active{% endif %}">
        <img src="{{ img | image_url: width: 2000 }}" 
          class="w-full h-auto object-contain"
          width="{{ img.width }}" 
          height="{{ img.height }}" 
          alt="{{ block.settings.alt | escape }}"
        />
        {% if section.settings.first_slide_eyebrow != blank and forloop.last == false %}
          <p class="facts-first-slide-eyebrow facts-first-slide-eyebrow--desktop font-bricolage font-bold text-black">
            {{ section.settings.first_slide_eyebrow }}
          </p>
        {% endif %}
      </div>
    {% endfor %}
  </div>
  {% comment %} version mobile {% endcomment %}
  <div class="md:hidden slides-wrapper-mobile relative w-full overflow-hidden">

    {% for block in section.blocks %}
      {% assign img = block.settings.image_mobile %}
      <div class="slide absolute inset-0 {% if forloop.first %}active{% endif %}">
        <img src="{{ img | img_url: '2000x2000' }}"
          class="w-full h-auto max-h-full object-contain mx-auto"
          width="{{ img.width }}" 
          height="{{ img.height }}" 
          alt="{{ block.settings.alt | escape }}"
        />
        {% if section.settings.first_slide_eyebrow != blank and forloop.last == false %}
          <p class="facts-first-slide-eyebrow facts-first-slide-eyebrow--mobile font-bricolage font-bold text-black">
            {{ section.settings.first_slide_eyebrow }}
          </p>
        {% endif %}
      </div>
    {% endfor %}
  </div>

  <!-- Flechas -->
  <div class="absolute grid grid-cols-2 md:bottom-5 md:right-5 bottom-3 right-2">
    <button class="prev text-white py-2 opacity-100 hover:opacity-60 transition duration-300">
      <div class="w-10 h-10 md:w-30 md:h-30 justify-center md:pl-15">
        {%- render 'arrow-slidder2' -%}
      </div>
    </button>

    <button class="next text-white py-2 opacity-100 hover:opacity-60 transition duration-300">
      <div class="w-10 h-10 md:w-30 md:h-30">
        {%- render 'arrow-slidder' -%}
      </div>
    </button>
  </div>
  
</div>

<style>
.custom-slider-facts {
  position: relative;
}

.custom-slider-facts .slides-wrapper {
  position: relative;
  width: 100%;
}

.custom-slider-facts .slide {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  opacity: 0;
  transition: opacity 0.5s ease;
}

.custom-slider-facts .slide.active {
  position: relative;
  opacity: 1;
}

.custom-slider-facts .slide img {
  display: block;
}

.custom-slider-facts .facts-first-slide-eyebrow {
  position: absolute;
  z-index: 10;
  margin: 0;
  line-height: 1;
  pointer-events: none;
}

.custom-slider-facts .facts-first-slide-eyebrow--desktop {
  display: none;
  top: 18%;
  left: 50%;
  right: 6%;
  font-size: clamp(2rem, 3.5vw, 3.25rem);
  text-align: left;
}

.custom-slider-facts .facts-first-slide-eyebrow--mobile {
  display: block;
  top: 11%;
  left: 50%;
  transform: translateX(-50%);
  width: 88%;
  font-size: clamp(1.75rem, 7.5vw, 2.25rem);
  text-align: center;
}

@media (min-width: 768px) {
  .custom-slider-facts .facts-first-slide-eyebrow--desktop {
    display: block;
  }

  .custom-slider-facts .facts-first-slide-eyebrow--mobile {
    display: none;
  }
}


</style>


<script>
document.addEventListener("DOMContentLoaded", function () {
  const slider = document.querySelector(".slider-facts-{{ section.id }}");
  if (!slider) return;

  function initSlider(wrapperSelector) {
    const wrapper = slider.querySelector(wrapperSelector);
    if (!wrapper) return;

    const slides = wrapper.querySelectorAll(".slide");
    const nextBtn = slider.querySelector(".next");
    const prevBtn = slider.querySelector(".prev");

    let index = 0;

    function showSlide(i) {
      slides.forEach(s => {
        s.classList.remove("active");
        s.style.position = "absolute";
      });
      slides[i].classList.add("active");
      slides[i].style.position = "relative";
    }

    nextBtn.onclick = () => {
      index = (index + 1) % slides.length;
      showSlide(index);
    };

    prevBtn.onclick = () => {
      index = (index - 1 + slides.length) % slides.length;
      showSlide(index);
    };
  }

  if (window.innerWidth < 768) {
    initSlider(".slides-wrapper-mobile");
  } else {
    initSlider(".slides-wrapper");
  }
});
</script>



{% schema %}
{
  "name": "Slider Facts",
  "settings": [
    {
      "type": "text",
      "id": "first_slide_eyebrow",
      "label": "Slide eyebrow",
      "default": "Did you know?"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Imagen Desktop",
      "settings": [
        { "type": "image_picker", "id": "image_desktop", "label": "Imagen Desktop" },
        { "type": "image_picker", "id": "image_mobile", "label": "Imagen Mobile" },
        { "type": "text", "id": "alt", "label": "Texto alternativo", "default": "Imagen del slider" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [{ "name": "Slider Facts" }]
}
{% endschema %}