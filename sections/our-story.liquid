<style>
  .our-story-section {
    width: 100vw;
    margin-left: calc(50% - 50vw);
    overflow-x: clip;
  }
  .our-story-content { padding-left: 22vw; padding-right: 22vw; }
  .our-story-deco-tr { top: auto !important; bottom: 0 !important; width: calc({{ section.settings.deco_size }}px * 2) !important; }
  @media (max-width: 767px) {
    .our-story-content { padding-left: 1.5rem; padding-right: 1.5rem; }
    .our-story-heading { font-size: 2.8rem !important; }
    .our-story-grid { grid-template-columns: 1fr !important; }
    .our-story-img { height: 180px !important; }
    .deco-top-left-img { width: 120px !important; top: -40px !important; left: 10px !important; }
    .our-story-deco { width: 70px !important; }
    .our-story-deco-tr { top: auto !important; bottom: 0; width: 110px !important; }
    .our-story-img-right-wrap { margin-top: 60px !important; order: 1; }
    .our-story-text-2 { order: 2; }
  }
</style>

<section
  class="our-story-section relative py-12 md:py-20"
  style="background-color: {{ section.settings.bg_color }}; position: relative; z-index: 1;"
>

  <!-- Deco top-left -->
  {% if section.settings.deco_top_left %}
    <div class="absolute pointer-events-none deco-top-left-img" style="width: calc({{ section.settings.deco_size }}px * 1.8); top: -130px; left: 50px; z-index: 9999;">
      <img
        src="{{ section.settings.deco_top_left | image_url: width: 600 }}"
        alt="" width="600" height="600"
        class="w-full object-contain"
      >
    </div>
  {% endif %}

  <!-- Deco top-right -->
  {% if section.settings.deco_top_right %}
    <div class="absolute top-0 right-0 pointer-events-none z-10 our-story-deco our-story-deco-tr" style="width: {{ section.settings.deco_size }}px;">
      <img
        src="{{ section.settings.deco_top_right | image_url: width: 600 }}"
        alt="" width="600" height="600"
        class="w-full object-contain"
      >
    </div>
  {% endif %}

  <!-- Deco bottom-left -->
  {% if section.settings.deco_bottom_left %}
    <div class="absolute bottom-0 left-0 pointer-events-none z-10 our-story-deco" style="width: {{ section.settings.deco_size }}px;">
      <img
        src="{{ section.settings.deco_bottom_left | image_url: width: 600 }}"
        alt="" width="600" height="600"
        class="w-full object-contain"
      >
    </div>
  {% endif %}

  <!-- Deco bottom-right -->
  {% if section.settings.deco_bottom_right %}
    <div class="absolute bottom-0 right-0 pointer-events-none z-10 our-story-deco" style="width: {{ section.settings.deco_size }}px;">
      <img
        src="{{ section.settings.deco_bottom_right | image_url: width: 600 }}"
        alt="" width="600" height="600"
        class="w-full object-contain"
      >
    </div>
  {% endif %}

  <div class="our-story-content relative z-20 w-full">

    <!-- ── Fila 1: imagen izquierda | heading + texto ── -->
    <div class="our-story-grid grid grid-cols-2 gap-8 md:gap-12 mb-8 md:mb-12 items-center">

      <!-- Imagen izquierda -->
      <div class="overflow-hidden rounded-2xl">
        {% if section.settings.image_left %}
          <img
            src="{{ section.settings.image_left | image_url: width: 900 }}"
            alt=""
            width="900" height="700"
            class="our-story-img w-full object-cover"
            style="height: {{ section.settings.image_height }}px;"
          >
        {% endif %}
      </div>

      <!-- Heading + textos -->
      <div class="flex flex-col justify-center gap-5">
        {% if section.settings.heading != blank %}
          <h2
            class="our-story-heading font-bricolage font-bold leading-none text-black"
            style="font-size: {{ section.settings.heading_size }}px;"
          >
            {{ section.settings.heading }}
          </h2>
        {% endif %}
        {% if section.settings.intro_text_1 != blank %}
          <p class="text-black text-sm md:text-base leading-relaxed">{{ section.settings.intro_text_1 }}</p>
        {% endif %}
        {% if section.settings.intro_text_2 != blank %}
          <p class="text-black text-sm md:text-base leading-relaxed">{{ section.settings.intro_text_2 }}</p>
        {% endif %}
      </div>

    </div>

    <!-- ── Fila 2: VIBBO texto | imagen derecha ── -->
    <div class="our-story-grid grid grid-cols-2 gap-8 md:gap-12 items-center">

      <!-- Descripción VIBBO -->
      <div class="flex flex-col justify-center gap-4 our-story-text-2">
        {% if section.settings.story_desc_1 != blank %}
          <p class="text-black text-sm md:text-base leading-relaxed">{{ section.settings.story_desc_1 }}</p>
        {% endif %}
        {% if section.settings.story_desc_2 != blank %}
          <p class="text-black text-sm md:text-base leading-relaxed">{{ section.settings.story_desc_2 }}</p>
        {% endif %}
      </div>

      <!-- Imagen derecha -->
      <div class="overflow-hidden rounded-2xl our-story-img-right-wrap" style="margin-top: 48px;">
        {% if section.settings.image_right %}
          <img
            src="{{ section.settings.image_right | image_url: width: 900 }}"
            alt=""
            width="900" height="700"
            class="our-story-img w-full object-cover"
            style="height: {{ section.settings.image_height }}px;"
          >
        {% endif %}
      </div>

    </div>

  </div>
</section>

{% schema %}
{
  "name": "Our Story",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#FFF4DA"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Title",
      "default": "Our story"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Title size (px)",
      "min": 40,
      "max": 140,
      "step": 4,
      "default": 96
    },
    {
      "type": "header",
      "content": "Row 1 — left image + text"
    },
    {
      "type": "image_picker",
      "id": "image_left",
      "label": "Image (left)"
    },
    {
      "type": "textarea",
      "id": "intro_text_1",
      "label": "Paragraph 1",
      "default": "We believe wellness begins at source. In the soil, in the hands that tend it, and in the traditions that have kept entire communities thriving for generations."
    },
    {
      "type": "textarea",
      "id": "intro_text_2",
      "label": "Paragraph 2",
      "default": "Real wellness doesn't start in a lab or a factory, but in the roots, with you."
    },
    {
      "type": "header",
      "content": "Row 2 — text + right image"
    },
    {
      "type": "text",
      "id": "story_label",
      "label": "Label",
      "default": "VIBBO"
    },
    {
      "type": "textarea",
      "id": "story_desc_1",
      "label": "Description paragraph 1",
      "default": "VIBBO was born from a desire to create more than a beverage: it's an experience rooted in authenticity, crafted with true natural ingredients and vibrant flavors."
    },
    {
      "type": "textarea",
      "id": "story_desc_2",
      "label": "Description paragraph 2",
      "default": "Each cup is designed as a sensory ritual that supports wellness and nourishes the body, celebrating tea in its purest, most honest form for your everyday ritual."
    },
    {
      "type": "image_picker",
      "id": "image_right",
      "label": "Image (right)"
    },
    {
      "type": "range",
      "id": "image_height",
      "label": "Image height (px)",
      "min": 200,
      "max": 600,
      "step": 20,
      "default": 280
    },
    {
      "type": "header",
      "content": "Decorative images"
    },
    {
      "type": "range",
      "id": "deco_size",
      "label": "Deco image size (px)",
      "min": 60,
      "max": 300,
      "step": 10,
      "default": 160
    },
    {
      "type": "image_picker",
      "id": "deco_top_left",
      "label": "Deco — top left"
    },
    {
      "type": "image_picker",
      "id": "deco_top_right",
      "label": "Deco — top right"
    },
    {
      "type": "image_picker",
      "id": "deco_bottom_left",
      "label": "Deco — bottom left"
    },
    {
      "type": "image_picker",
      "id": "deco_bottom_right",
      "label": "Deco — bottom right"
    }
  ],
  "presets": [
    {
      "name": "Our Story"
    }
  ]
}
{% endschema %}
