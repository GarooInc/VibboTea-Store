<div class="w-full overflow-x-auto md:py-10 py-5 md:pt-30">
    <div class="md:block flex w-full md:justify-left justify-center md:pl-20">
      <h2 class="py-10 text-black text-[7vw] md:text-[3.4vw] 
        font-bricolage font-semibold leading-[1.1] md:text-left text-center">
        {{ section.settings.title | newline_to_br
         | replace: 'Vibbo', '<span class=" uppercase font-grafika font-normal  text-[6.5vw] md:text-[3.4vw]">VIBBO</span>' }}
        
      </h2>
      
       
    </div>
    <div class="hidden md:flex justify-center items-center px-5 md:px-20">
        <img src="{{ section.settings.image | img_url: 'master' }}" 
            alt="Why Vibbo Image" 
            class="w-full h-auto max-w-lg md:max-w-none"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
        />
    </div>

    <div class="md:hidden flex justify-center items-center px-5 md:px-20">
        <div style="position: relative; display: inline-block; cursor: zoom-in;" id="why-vibbo-zoom-trigger">
            <img src="{{ section.settings.image_mobile | img_url: 'master' }}"
                alt="Why Vibbo Image"
                class="w-full h-auto max-w-lg md:max-w-none"
                width="{{ section.settings.image_mobile.width }}"
                height="{{ section.settings.image_mobile.height }}"
            />
            <div style="position: absolute; bottom: 8px; right: 8px; background: rgba(0,0,0,0.5); border-radius: 9999px; padding: 6px; pointer-events: none; display: flex; align-items: center; justify-content: center;">
                <svg xmlns="http://www.w3.org/2000/svg" style="width: 18px; height: 18px; display: block;" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2">
                    <circle cx="11" cy="11" r="7"/>
                    <line x1="16.5" y1="16.5" x2="21" y2="21"/>
                </svg>
            </div>
        </div>
    </div>

</div>

<!-- Lightbox overlay (fuera del contenedor para evitar conflictos con overflow) -->
<div id="why-vibbo-lightbox" style="display: none; position: fixed; inset: 0; z-index: 9999; background: rgba(0,0,0,0.92); align-items: center; justify-content: center;">
    <button id="why-vibbo-close" style="position: absolute; top: 16px; right: 16px; background: rgba(255,255,255,0.15); border: none; border-radius: 9999px; width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; cursor: pointer; z-index: 10;">
        <svg xmlns="http://www.w3.org/2000/svg" style="width: 18px; height: 18px; display: block;" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
    </button>
    <img src="{{ section.settings.image_mobile | img_url: 'master' }}"
        alt="Why Vibbo Image"
        style="max-width: 100%; max-height: 100%; object-fit: contain; touch-action: pinch-zoom;"
    />
</div>

<script>
    (function() {
        var trigger = document.getElementById('why-vibbo-zoom-trigger');
        var lightbox = document.getElementById('why-vibbo-lightbox');
        var closeBtn = document.getElementById('why-vibbo-close');

        trigger.addEventListener('click', function() {
            lightbox.style.display = 'flex';
            document.body.style.overflow = 'hidden';
        });

        function closeLightbox() {
            lightbox.style.display = 'none';
            document.body.style.overflow = '';
        }

        closeBtn.addEventListener('click', function(e) {
            e.stopPropagation();
            closeLightbox();
        });
        lightbox.addEventListener('click', function(e) {
            if (e.target === lightbox) closeLightbox();
        });
    })();
</script>






{% schema %}
{
  "name": "Product Why Vibbo Image",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Why Vibbo?"
    }, 
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Image Mobile",
    }
  ],
  
  "presets": [
    {
      "name": "Product Why Vibbo Image"
    }
  ]
}
{% endschema %}