<style>
  .testimonials-section {
    width: 100vw;
    margin-left: calc(50% - 50vw);
  }
  .testimonials-content {
    padding-left: 22vw;
    padding-right: 22vw;
  }
  .testimonial-card {
    background: #fff;
    border-radius: 1rem;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .testimonial-stars { color: #FFCD51; font-size: 1.1rem; }
  @media (max-width: 767px) {
    .testimonials-content { padding-left: 1.5rem; padding-right: 1.5rem; }
    .testimonials-grid { grid-template-columns: 1fr !important; }
    .testimonials-heading { font-size: 1.6rem !important; }
  }
</style>

<section class="testimonials-section py-12 md:py-16" style="background-color: {{ section.settings.bg_color }};">
  <div class="testimonials-content w-full">

    <!-- Header -->
    <div class="flex items-center justify-between mb-8 md:mb-12">
      <h2
        class="testimonials-heading font-bricolage font-bold text-black"
        style="font-size: {{ section.settings.heading_size }}px;"
      >
        {{ section.settings.heading }}
      </h2>
      <div class="flex gap-2" id="testimonials-nav-{{ section.id }}">
        <button class="testimonials-prev-{{ section.id }} w-9 h-9 rounded-full border border-black flex items-center justify-center hover:bg-black hover:text-white transition">
          &#8592;
        </button>
        <button class="testimonials-next-{{ section.id }} w-9 h-9 rounded-full border border-black flex items-center justify-center hover:bg-black hover:text-white transition">
          &#8594;
        </button>
      </div>
    </div>

    <!-- Cards -->
    <div class="testimonials-track overflow-hidden">
      <div
        class="testimonials-grid grid gap-6"
        id="testimonials-grid-{{ section.id }}"
        style="grid-template-columns: repeat({{ section.settings.cards_visible }}, 1fr); transition: transform 0.4s ease;"
      >
        {% for block in section.blocks %}
          {% if block.type == 'testimonial' %}
            <div class="testimonial-card">
              <!-- Top: avatar + name -->
              <div class="flex items-center gap-3">
                {% if block.settings.avatar %}
                  <img
                    src="{{ block.settings.avatar | image_url: width: 200 }}"
                    alt="{{ block.settings.name }}"
                    width="200" height="200"
                    class="w-12 h-12 rounded-full object-cover flex-shrink-0"
                  >
                {% else %}
                  <div class="w-12 h-12 rounded-full bg-gray-200 flex-shrink-0"></div>
                {% endif %}
                <span class="font-bricolage font-semibold text-black text-sm">{{ block.settings.name }}</span>
              </div>
              <!-- Text -->
              {% if block.settings.text != blank %}
                <p class="text-black text-sm leading-relaxed">{{ block.settings.text }}</p>
              {% endif %}
              <!-- Stars -->
              <div class="testimonial-stars">
                {% assign stars = block.settings.stars | default: 5 %}
                {% for i in (1..stars) %}★{% endfor %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>

  </div>
</section>

<script>
(function() {
  var grid = document.getElementById('testimonials-grid-{{ section.id }}');
  var prevBtn = document.querySelector('.testimonials-prev-{{ section.id }}');
  var nextBtn = document.querySelector('.testimonials-next-{{ section.id }}');
  if (!grid || !prevBtn || !nextBtn) return;

  var cards = grid.children;
  var visible = {{ section.settings.cards_visible }};
  var current = 0;
  var total = cards.length;

  function updateSlider() {
    var cardWidth = grid.parentElement.offsetWidth / visible;
    grid.style.transform = 'translateX(-' + (current * cardWidth) + 'px)';
  }

  nextBtn.addEventListener('click', function() {
    if (current < total - visible) { current++; updateSlider(); }
  });
  prevBtn.addEventListener('click', function() {
    if (current > 0) { current--; updateSlider(); }
  });

  window.addEventListener('resize', updateSlider);
})();
</script>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#F5F5F0"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Hear what others have to say"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size (px)",
      "min": 20,
      "max": 80,
      "step": 2,
      "default": 36
    },
    {
      "type": "range",
      "id": "cards_visible",
      "label": "Cards visible at once",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Profile photo"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Sarah Williams"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Review text",
          "default": "I absolutely love this tea. The quality is amazing and the flavors are so vibrant!"
        },
        {
          "type": "range",
          "id": "stars",
          "label": "Stars",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}
