<!-- TÍTULO -->
{% if section.settings.section_title != blank %}
  <div class="text-center items-center align-center pt-15">
    <h2 class="md:text-5xl text-3xl text-black font-semibold font-bricolage pb-5">
      {{ section.settings.section_title  | newline_to_br }}
    </h2>
  </div>
{% endif %}

{% if section.settings.collection != blank %}
  {% assign coll = collections[section.settings.collection] %}
{% else %}
  {% assign coll = collection %}
{% endif %}

{% if coll %}

<section class="relative w-full pt-4">

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-10
    px-4 md:px-10 py-10 md:py-16">
    {% for product in coll.products %}
      <div class="flex flex-col">

        <a href="{{ product.url }}" class="block">
          <div class="w-full aspect-5/5 rounded-2xl overflow-hidden bg-white">
            {% if product.media.size > 1 %}
                {% assign second_image = product.media[0] %}
                
                <div class="w-full md:h-[30vw] bg-white rounded-2xl overflow-hidden flex items-center justify-center">
                  <img
                    src="{{ second_image | image_url: width: 800 }}"
                    alt="{{ second_image.alt | escape }}"
                    width="{{ second_image.width }}"
                    height="{{ second_image.height }}"
                    loading="lazy"
                    class="w-full h-auto object-cover scale-125 hover:scale-135 transition-transform duration-350"
                  >
                </div>

              {% elsif product.featured_media %}
                <!-- fallback -->
                <div class="w-full md:h-[30vw] bg-white rounded-2xl overflow-hidden flex items-center justify-center">
                  <img
                    src="{{ product.featured_media | image_url: width: 800 }}"
                    alt="{{ product.featured_media.alt | escape }}"
                    width="{{ product.featured_media.width }}"
                    height="{{ product.featured_media.height }}"
                    class="w-full h-auto object-cover"
                  >
                </div>
              {% else %}
                <div class="w-full md:h-[30vw]  rounded-2xl overflow-hidden bg-gray-200" ></div>
              {% endif %}
          </div>

          <p class="font-bricolage text-lg md:text-xl text-[#575757] pt-3">
            {{ product.title }}
          </p>

          {% if section.settings.show_ribbon %}
            {% assign ribbon_text = section.settings.ribbon_text_default %}
            {% assign title_lower = product.title | downcase %}
            {% if title_lower contains 'caja' or title_lower contains 'box' %}
              {% assign ribbon_text = section.settings.ribbon_text_caja %}
            {% endif %}
            <div class="kick-promo-ribbon">
              <span>{{ ribbon_text }}</span>
            </div>
          {% endif %}

          <p class="font-bricolage text-xl md:text-2xl text-black font-medium">
            {{ product.price | money }}
          </p>
        </a>

        <!-- ADD TO CART -->
        <form method="post" action="{{ routes.cart_add_url }}" class="pt-3">
          <input
            type="hidden"
            name="id"
            value="{{ product.selected_or_first_available_variant.id }}"
          >

          <button
            type="submit"
            class="
              bg-black w-full rounded-3xl md:py-3 py-2 flex items-center
              justify-center hover:opacity-70 transition-opacity"
          >
            <span class="font-bricolage text-white md:text-sm text-xs uppercase font-light">
              {{ section.settings.text_add }}
            </span>
          </button>
        </form>

      </div>
    {% endfor %}
  </div>

</section>

{% endif %}


<style>
.kick-promo-ribbon {
  display: inline-block;
  background-color: #DC2626;
  color: #fff;
  font-family: 'Bricolage Grotesque', sans-serif;
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.02em;
  padding: 4px 12px;
  border-radius: 2px;
  margin-top: 4px;
  position: relative;
  line-height: 1.4;
  box-shadow: 2px 2px 0px rgba(0,0,0,0.15);
  text-transform: uppercase;
}
.kick-promo-ribbon::before,
.kick-promo-ribbon::after {
  content: '';
  position: absolute;
  top: 0;
  width: 0;
  height: 0;
  border-style: solid;
}
.kick-promo-ribbon::before {
  left: -8px;
  border-width: 0 0 100% 8px;
  border-color: transparent transparent #DC2626 transparent;
  height: 100%;
  border-width: 0 8px 100% 0;
  border-color: transparent #DC2626 transparent transparent;
}
</style>

{% schema %}
{
  "name": "Main Shop",
  "settings": [
    {
      "type": "textarea",
      "id": "section_title",
      "label": "Title",
    },
    {
      "type": "textarea",
      "id": "desc",
      "label": "Descripcion",
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Colección"
    },
    {
      "type": "number",
      "id": "limit",
      "label": "Número máximo de productos",
      "default": 12
    },
    {
      "type": "text",
      "id": "text_add",
      "label": "Texto del boton de añadir",
      "default": "ADD TO CART"
    },
    {
      "type": "checkbox",
      "id": "show_ribbon",
      "label": "Mostrar cinta promo",
      "default": false
    },
    {
      "type": "text",
      "id": "ribbon_text_default",
      "label": "Texto cinta (productos normales)",
      "default": "Secure yours now with 20% off, arriving in May"
    },
    {
      "type": "text",
      "id": "ribbon_text_caja",
      "label": "Texto cinta (La Caja / Box)",
      "default": "Secure yours now with 15% off, arriving in May"
    }

  ],
  "presets": [
    {
      "name": "Main Shop",
      "category": "Productos"
    }
  ]
}
{% endschema %}
