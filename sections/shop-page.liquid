<!-- TÍTULO -->
{% if section.settings.section_title != blank %}
  <div class="text-center items-center align-center pt-15">
    <h2 class="md:text-5xl text-3xl text-black font-semibold font-bricolage pb-5">
      {{ section.settings.section_title  | newline_to_br }}
    </h2>
  </div>
{% endif %}

{% if section.settings.collection != blank %}
  {% assign coll = collections[section.settings.collection] %}
{% else %}
  {% assign coll = collection %}
{% endif %}

{% if coll %}

<section class="relative w-full pt-4">

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-10
    px-4 md:px-10 py-10 md:py-16">
    {% for product in coll.products %}
      {% assign product_image_class = 'absolute inset-0 w-full h-full object-cover object-center' %}
      {% assign product_image_style = '' %}
      {% if product.handle == 'assorted-reset-bundle-set' %}
        {% assign product_image_style = 'object-position: center 38%;' %}
      {% endif %}

      <div class="flex flex-col">

        <a href="{{ product.url }}" class="block">
          <div class="relative w-full aspect-square rounded-2xl overflow-hidden bg-white group">
            {%- assign has_sold_out_tag = false -%}
            {%- if product.tags contains 'Sold Out' -%}
              {%- assign has_sold_out_tag = true -%}
            {%- endif -%}
            {%- assign negative_stock = true -%}
            {%- for variant in product.variants -%}
              {%- if variant.inventory_management == blank -%}
                {%- assign negative_stock = false -%}
                {%- break -%}
              {%- elsif variant.inventory_quantity > 0 -%}
                {%- assign negative_stock = false -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}
            {%- if has_sold_out_tag or negative_stock -%}
              <div class="absolute top-[22px] left-3 z-10 text-black text-sm md:text-base font-bricolage uppercase px-4 py-1.5 rounded-full" style="background-color: #fab801;">
                Sold Out
              </div>
            {%- endif -%}
            {% liquid
              assign primary_media = product.media[0] | default: product.featured_media
              assign hover_media_index = 1
              if product.handle == 'assorted-reset-bundle-set' or product.handle == 'filter-bags'
                assign hover_media_index = 1
              endif
              assign hover_media = nil
              if product.media.size > hover_media_index
                assign hover_media = product.media[hover_media_index]
              endif
            %}
            {% if primary_media %}
              <img
                src="{{ primary_media | image_url: width: 800 }}"
                alt="{{ primary_media.alt | escape }}"
                width="{{ primary_media.width }}"
                height="{{ primary_media.height }}"
                loading="lazy"
                class="{{ product_image_class }}{% if hover_media %} transition-opacity duration-350 group-hover:opacity-0{% else %} hover:scale-105 transition-transform duration-350{% endif %}"
                {% if product_image_style != '' %}style="{{ product_image_style }}"{% endif %}
              >
            {% elsif product.featured_media %}
              <img
                src="{{ product.featured_media | image_url: width: 800 }}"
                alt="{{ product.featured_media.alt | escape }}"
                width="{{ product.featured_media.width }}"
                height="{{ product.featured_media.height }}"
                class="{{ product_image_class }}"
                {% if product_image_style != '' %}style="{{ product_image_style }}"{% endif %}
              >
            {% else %}
              <div class="w-full h-full bg-gray-200"></div>
            {% endif %}
            {% if hover_media %}
              <img
                src="{{ hover_media | image_url: width: 800 }}"
                alt="{{ hover_media.alt | escape }}"
                width="{{ hover_media.width }}"
                height="{{ hover_media.height }}"
                loading="lazy"
                class="{{ product_image_class }} opacity-0 transition-opacity duration-350 group-hover:opacity-100"
                {% if product_image_style != '' %}style="{{ product_image_style }}"{% endif %}
              >
            {% endif %}
          </div>

          <p class="font-bricolage text-lg md:text-xl text-[#575757] pt-3">
            {{ product.title }}
          </p>
        </a>

        <div class='jdgm-widget jdgm-preview-badge' data-id='{{ product.id }}'>
          {{ product.metafields.judgeme.badge }}
        </div>

        <p class="font-bricolage text-xl md:text-2xl text-black font-medium">
          {{ product.price | money }}
        </p>

        <!-- ADD TO CART -->
        <form method="post" action="{{ routes.cart_add_url }}" class="pt-3">
          <input
            type="hidden"
            name="id"
            value="{{ product.selected_or_first_available_variant.id }}"
          >

          <button
            type="submit"
            class="
              bg-black w-full rounded-3xl md:py-3 py-2 flex items-center
              justify-center hover:opacity-70 transition-opacity"
          >
            <span class="font-bricolage text-white md:text-sm text-xs uppercase font-light">
              {{ section.settings.text_add }}
            </span>
          </button>
        </form>

      </div>
    {% endfor %}
  </div>

</section>

{% endif %}

{% schema %}
{
  "name": "Main Shop",
  "settings": [
    {
      "type": "textarea",
      "id": "section_title",
      "label": "Title",
    },
    {
      "type": "textarea",
      "id": "desc",
      "label": "Descripcion",
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Colección"
    },
    {
      "type": "number",
      "id": "limit",
      "label": "Número máximo de productos",
      "default": 12
    },
    {
      "type": "text",
      "id": "text_add",
      "label": "Texto del boton de añadir",
      "default": "ADD TO CART"
    },

  ],
  "presets": [
    {
      "name": "Main Shop",
      "category": "Productos"
    }
  ]
}
{% endschema %}
