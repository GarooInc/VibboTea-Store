{% doc %}
  Renders a compact row of product features with icons.
  
  Displays 4 key product characteristics: 100% Natural, No Added Sugar,
  No Microplastics, and 30-Day Guarantee. Layout is responsive with
  2x2 grid on mobile/tablet and a single horizontal row on large desktop.

  @example
  {% render 'product-features-row' %}
{% enddoc %}

<div class="product-features-row">
  <div class="product-features-row__grid">
    
    <!-- 100% Natural -->
    <div class="product-features-row__item">
      <div class="product-features-row__icon-wrap">
        <img 
          src="{{ '100-natural.svg' | asset_url }}" 
          alt="100% Natural" 
          class="product-features-row__icon"
          width="96"
          height="96"
        >
      </div>
      <span class="product-features-row__text">{{ 'product_features.natural' | t }}</span>
    </div>

    <!-- No Added Sugar -->
    <div class="product-features-row__item">
      <div class="product-features-row__icon-wrap">
        <img 
          src="{{ 'no-added-sugar.svg' | asset_url }}" 
          alt="No Added Sugar" 
          class="product-features-row__icon"
          width="96"
          height="96"
        >
      </div>
      <span class="product-features-row__text">{{ 'product_features.no_sugar' | t }}</span>
    </div>

    <!-- No Microplastics -->
    <div class="product-features-row__item">
      <div class="product-features-row__icon-wrap">
        <img 
          src="{{ 'no-microplastics.svg' | asset_url }}" 
          alt="No Microplastics" 
          class="product-features-row__icon"
          width="96"
          height="96"
        >
      </div>
      <span class="product-features-row__text">{{ 'product_features.no_microplastics' | t }}</span>
    </div>

    <!-- 30-Day Guarantee -->
    <div class="product-features-row__item">
      <div class="product-features-row__icon-wrap">
        <img 
          src="{{ '30-day-guarantee.svg' | asset_url }}" 
          alt="30-Day Guarantee" 
          class="product-features-row__icon"
          width="96"
          height="96"
        >
      </div>
      <span class="product-features-row__text">{{ 'product_features.guarantee' | t }}</span>
    </div>

  </div>
</div>

{% stylesheet %}
  .product-features-row {
    width: 100%;
    max-width: 100%;
    min-width: 0;
    padding: 0.75rem 0;
    margin: 1rem 0;
    background-color: #ffffff;
    overflow: hidden;
  }

  .product-features-row__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem 1rem;
    width: 100%;
    max-width: 100%;
    min-width: 0;
  }

  @media (min-width: 768px) {
    .product-features-row {
      padding: 0;
      margin: 1rem 0;
    }
  }

  .product-features-row__item {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    align-items: center;
    column-gap: 0.25rem;
    width: 100%;
    min-width: 0;
  }

  .product-features-row__icon-wrap {
    width: fit-content;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    flex-shrink: 0;
  }

  .product-features-row__icon {
    width: 96px;
    height: 96px;
    flex-shrink: 0;
    display: block;
    object-fit: contain;
    object-position: left center;
  }

  .product-features-row__text {
    font-family: var(--font-bricolage, sans-serif);
    font-size: 0.6rem;
    font-weight: 700;
    line-height: 1.15;
    color: #1a1a1a;
    text-transform: uppercase;
    letter-spacing: 0.005em;
    text-align: left;
    flex: 1;
    min-width: 0;
    align-self: center;
    overflow-wrap: normal;
    word-break: normal;
    margin-left: -1.65rem;
  }

  @media (min-width: 768px) {
    .product-features-row__text {
      font-size: 0.65rem;
    }
  }

  @media (min-width: 1024px) {
    .product-features-row__grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 0.4rem 0.5rem;
      align-items: stretch;
    }

    .product-features-row__item {
      column-gap: 0.2rem;
    }

    .product-features-row__icon-wrap {
      width: fit-content;
    }

    .product-features-row__icon {
      width: 72px;
      height: 72px;
    }

    .product-features-row__text {
      text-align: left;
      font-size: 0.55rem;
      line-height: 1.2;
      margin-left: -1.25rem;
    }
  }

  @media (min-width: 1280px) {
    .product-features-row__grid {
      gap: 0.5rem 0.65rem;
    }

    .product-features-row__item {
      column-gap: 0.2rem;
    }

    .product-features-row__icon {
      width: 88px;
      height: 88px;
    }

    .product-features-row__text {
      font-size: 0.6rem;
      margin-left: -1.5rem;
    }
  }

  @media (min-width: 1440px) {
    .product-features-row__icon {
      width: 96px;
      height: 96px;
    }

    .product-features-row__text {
      font-size: 0.65rem;
      margin-left: -1.65rem;
    }
  }
{% endstylesheet %}
