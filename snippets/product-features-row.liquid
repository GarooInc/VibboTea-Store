{% doc %}
  Renders a compact row of product features with icons.
  
  Displays 4 key product characteristics: 100% Natural, No Added Sugar,
  No Microplastics, and 30-Day Guarantee. Layout is responsive with
  2 columns on mobile and 4 columns on desktop.

  @example
  {% render 'product-features-row' %}
{% enddoc %}

<div class="product-features-row">
  <div class="product-features-row__grid">
    
    <!-- 100% Natural -->
    <div class="product-features-row__item">
      <div class="product-features-row__icon-wrap">
        <img 
          src="{{ '100-natural.svg' | asset_url }}" 
          alt="100% Natural" 
          class="product-features-row__icon"
          width="48"
          height="48"
        >
      </div>
      <span class="product-features-row__text">{{ 'product_features.natural' | t }}</span>
    </div>

    <!-- No Added Sugar -->
    <div class="product-features-row__item">
      <div class="product-features-row__icon-wrap">
        <img 
          src="{{ 'no-added-sugar.svg' | asset_url }}" 
          alt="No Added Sugar" 
          class="product-features-row__icon"
          width="48"
          height="48"
        >
      </div>
      <span class="product-features-row__text">{{ 'product_features.no_sugar' | t }}</span>
    </div>

    <!-- No Microplastics -->
    <div class="product-features-row__item">
      <div class="product-features-row__icon-wrap">
        <img 
          src="{{ 'no-microplastics.svg' | asset_url }}" 
          alt="No Microplastics" 
          class="product-features-row__icon"
          width="48"
          height="48"
        >
      </div>
      <span class="product-features-row__text">{{ 'product_features.no_microplastics' | t }}</span>
    </div>

    <!-- 30-Day Guarantee -->
    <div class="product-features-row__item">
      <div class="product-features-row__icon-wrap">
        <img 
          src="{{ '30-day-guarantee.svg' | asset_url }}" 
          alt="30-Day Guarantee" 
          class="product-features-row__icon"
          width="48"
          height="48"
        >
      </div>
      <span class="product-features-row__text">{{ 'product_features.guarantee' | t }}</span>
    </div>

  </div>
</div>

{% stylesheet %}
  .product-features-row {
    width: 100%;
    padding: 0.75rem 0;
    margin: 1rem 0;
    background-color: #ffffff;
  }

  .product-features-row__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem 1rem;
    width: 100%;
  }

  @media (min-width: 768px) {
    .product-features-row {
      padding: 0;
      margin: 1rem 0;
    }
    
    .product-features-row__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem 1.5rem;
      width: 100%;
    }
  }

  .product-features-row__item {
    display: grid;
    grid-template-columns: 52px minmax(0, 1fr);
    align-items: center;
    column-gap: 0.5rem;
    width: 100%;
  }

  .product-features-row__icon-wrap {
    width: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-features-row__icon {
    width: 48px;
    height: 48px;
    flex-shrink: 0;
    display: block;
    object-fit: contain;
  }

  @media (min-width: 768px) {
    .product-features-row__item {
      grid-template-columns: 72px minmax(0, 1fr);
      column-gap: 0.75rem;
      width: 100%;
    }

    .product-features-row__icon-wrap {
      width: 72px;
    }

    .product-features-row__icon {
      width: 72px;
      height: 72px;
    }
  }

  .product-features-row__text {
    font-family: var(--font-bricolage, sans-serif);
    font-size: 0.6rem;
    font-weight: 700;
    line-height: 1.15;
    color: #1a1a1a;
    text-transform: uppercase;
    letter-spacing: 0.005em;
    text-align: left;
    flex: 1;
    min-width: 0;
    align-self: center;
  }

  @media (min-width: 768px) {
    .product-features-row__text {
      font-size: 0.75rem;
      line-height: 1.2;
      max-width: none;
      white-space: normal;
      overflow-wrap: anywhere;
    }
  }
{% endstylesheet %}
